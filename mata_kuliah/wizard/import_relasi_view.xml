<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_import_relasi_mata_kuliah_form" model="ir.ui.view">
        <field name="name">import.relasi.mata.kuliah.form</field>
        <field name="model">import.relasi.mata.kuliah</field>
        <field name="arch" type="xml">
            <form string="Import Relasi Mata Kuliah">
                <group>
                    <field name="import_type" widget="radio"/>
                    <field name="file_data" filename="file_name"/>
                    <field name="file_name" invisible="1"/>
                </group>
                <footer>
                    <button name="action_import" string="Import" type="object" class="btn-primary"/>
                    <button name="action_download_template" string="Download Template" type="object" class="btn-secondary"/>
                    <button string="Batal" class="btn-default" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_import_relasi_mata_kuliah" model="ir.actions.act_window">
        <field name="name">Import Relasi Mata Kuliah</field>
        <field name="res_model">import.relasi.mata.kuliah</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- Menu Item under Mata Kuliah -->
    <menuitem id="menu_import_relasi_mata_kuliah"
              name="Import Relasi"
              parent="mata_kuliah.menu_mata_kuliah"
              action="action_import_relasi_mata_kuliah"
              sequence="20"/>
</odoo>
