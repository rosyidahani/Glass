<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_mata_kuliah_tree" model="ir.ui.view">
    <field name="name">mata.kuliah.tree</field>
    <field name="model">mata.kuliah</field>
    <field name="arch" type="xml">
      <tree>
        <field name="kode"/>
        <field name="nama"/>
        <field name="sks"/>
        <field name="semester"/>
        <field name="dosen_pengampu"/>
      </tree>
    </field>
  </record>

  <record id="view_mata_kuliah_form" model="ir.ui.view">
    <field name="name">mata.kuliah.form</field>
    <field name="model">mata.kuliah</field>
    <field name="arch" type="xml">
      <form>
        <sheet>
          <group>
            <field name="kode"/>
            <field name="nama"/>
            <field name="sks"/>
            <field name="semester"/>
            <field name="dosen_ids" widget="many2many_tags" options="{'no_create': True}"/>
          </group>
          <notebook>
            <page string="Daftar Mahasiswa">
              <field name="mahasiswa_ids">
                <tree>
                  <field name="nim"/>
                  <field name="name"/>
                  <field name="semester"/>
                </tree>
              </field>
            </page>
          </notebook>
        </sheet>
      </form>
    </field>
  </record>

  <record id="action_mata_kuliah" model="ir.actions.act_window">
    <field name="name">Mata Kuliah</field>
    <field name="res_model">mata.kuliah</field>
    <field name="view_mode">tree,form</field>
  </record>

  <menuitem id="menu_mata_kuliah"
            name="Mata Kuliah"
            action="action_mata_kuliah"
            sequence="25"/>
</odoo>