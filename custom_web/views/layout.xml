<odoo>
    <template id="layout">
        <html>
            <head>
                <meta charset="utf-8"/>
                <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no"/>
                <title>Portal Mahasiswa</title>
                <link rel="stylesheet" href="/custom_web/static/src/css/variables.css"/>
                <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"/>
                <link rel="stylesheet" href="/custom_web/static/src/css/layout.css"/>
                <link rel="stylesheet" href="/custom_web/static/src/css/presensi.css"/>
                <link rel="stylesheet" href="/custom_web/static/src/css/dosen_presensi.css"/>
                <link rel="stylesheet" href="/custom_web/static/src/css/tugas_dosen.css"/>
                <link rel="stylesheet" href="/custom_web/static/src/css/tugas_mahasiswa.css"/>
                <link rel="stylesheet" href="/custom_web/static/src/css/shop.css"/>
                <link rel="stylesheet" href="/custom_web/static/src/css/leaderboard.css"/>
                <script type="text/javascript">
                    (function() {
                        const savedTheme = localStorage.getItem("portal_theme") || "ocean";
                        document.documentElement.className = "theme-" + savedTheme;
                    })();
                </script>
                <script src="/custom_web/static/src/js/portal_i18n.js?v=7" type="text/javascript"></script>
                <script src="/custom_web/static/src/js/settings_handler.js?v=7" type="text/javascript"></script>
                <script src="/custom_web/static/src/js/presensi.js" type="text/javascript"></script>
                <script src="/custom_web/static/src/js/tugas_dosen.js" type="text/javascript"></script>
                <script src="/custom_web/static/src/js/tugas_mahasiswa.js" type="text/javascript"></script>
                <script src="/custom_web/static/src/js/shop.js" type="text/javascript"></script>
            </head>
            <body>
                <div class="app-container">
                    <div class="sidebar">
                        <div class="sidebar-header">
                            <h3><i class="bi bi-mortarboard-fill" style="color: #3b82f6;"></i> Portal</h3>
                            <div class="user-name">
                                <t t-if="request.session.get('dosen_id')">
                                    <t t-esc="request.session.get('dosen_name', 'Dosen')"/>
                                </t>
                                <t t-else="">
                                    <t t-esc="request.session.get('mahasiswa_name', 'Student')"/>
                                </t>
                            </div>
                        </div>
                        
                        <t t-if="request.session.get('dosen_id')">
                            <ul class="sidebar-nav">
                                <li><a href="/dashboard" t-att-class="'active' if request.httprequest.path.startswith('/dashboard') else ''"><span class="icon"><i class="bi bi-house-door-fill"></i></span> <span data-translate-id="sidebar_home">Home</span></a></li>
                                <li><a href="/dosen/presensi" t-att-class="'active' if request.httprequest.path == '/dosen/presensi' else ''"><span class="icon"><i class="bi bi-calendar-check-fill"></i></span> <span data-translate-id="sidebar_presensi_mhs">Presensi Mahasiswa</span></a></li>
                                <li><a href="/dosen/tugas" t-att-class="'active' if request.httprequest.path == '/dosen/tugas' else ''"><span class="icon"><i class="bi bi-journal-text"></i></span> <span data-translate-id="sidebar_tugas">Tugas</span></a></li>
                                <li><a href="/dosen/leaderboard" t-att-class="'active' if request.httprequest.path == '/dosen/leaderboard' else ''"><span class="icon"><i class="bi bi-trophy-fill"></i></span> <span data-translate-id="sidebar_leaderboard">Leaderboard</span></a></li>
                            </ul>
                        </t>

                        <t t-else="">
                            <ul class="sidebar-nav">
                                <li><a href="/dashboard" t-att-class="'active' if request.httprequest.path.startswith('/dashboard') else ''"><span class="icon"><i class="bi bi-house-door-fill"></i></span> <span data-translate-id="sidebar_home">Home</span></a></li>
                                <li><a href="/presensi" t-att-class="'active' if request.httprequest.path == '/presensi' else ''"><span class="icon"><i class="bi bi-calendar-check-fill"></i></span> <span data-translate-id="sidebar_presensi">Presensi</span></a></li>
                                <li><a href="/tugas" t-att-class="'active' if request.httprequest.path == '/tugas' else ''"><span class="icon"><i class="bi bi-clipboard-data-fill"></i></span> <span data-translate-id="sidebar_tugas">Tugas</span></a></li>
                                <li><a href="/leaderboard" t-att-class="'active' if request.httprequest.path == '/leaderboard' else ''"><span class="icon"><i class="bi bi-trophy-fill"></i></span> <span data-translate-id="sidebar_leaderboard">Leaderboard</span></a></li>
                            </ul>
                        </t>
                    </div>
                    <div class="main-content">
                        <t t-raw="0"/>
                    </div>
                </div>
            </body>
        </html>
    </template>

    <!-- Reusable Shared Student Header -->
    <template id="shared_student_header" name="Shared Student Header">
        <div class="mhs-header-hud">
            <div class="hud-profile-meta">
                <t t-if="back_url">
                    <a t-att-href="back_url" class="back-btn-header" style="margin-right: 8px;"><i class="bi bi-arrow-left"></i></a>
                </t>
                <h2><t t-esc="title"/></h2>
            </div>
            <div class="avatar-circle-header-container" style="display: flex; align-items: center; gap: 12px;">
                <t t-if="show_coins">
                    <div class="coin-display sync-coins" title="Saldo koin Anda">
                        <i class="bi bi-coin"></i> <t t-esc="mahasiswa.koin"/> Poin
                    </div>
                </t>
                <t t-if="show_xp">
                    <div class="xp-display" title="Poin XP Anda saat ini">
                        <i class="bi bi-star-fill text-warning me-1"></i> <t t-esc="mahasiswa.total_xp"/> XP
                    </div>
                </t>
                <div class="avatar-circle-header">
                    <t t-if="mahasiswa and mahasiswa.foto_profil">
                        <img t-att-src="'data:image/png;base64,' + mahasiswa.foto_profil.decode('utf-8')" alt="Profile" class="avatar-img-round"/>
                    </t>
                    <t t-else="">
                        <span class="avatar-shortcut"><i class="bi bi-person-fill"></i></span>
                    </t>
                </div>
            </div>
        </div>
    </template>
</odoo>