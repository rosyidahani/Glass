<odoo>
    <template id="layout">
        <html>
            <head>
                <meta charset="utf-8"/>
                <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no"/>
                <title>Portal Mahasiswa</title>
                <link rel="stylesheet" href="/custom_web/static/src/css/variables.css"/>
                <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"/>
                <link rel="stylesheet" href="/custom_web/static/src/css/layout.css"/>
                <link rel="stylesheet" href="/custom_web/static/src/css/presensi.css"/>
                <link rel="stylesheet" href="/custom_web/static/src/css/dosen_presensi.css"/>
                <link rel="stylesheet" href="/custom_web/static/src/css/tugas_dosen.css"/>
                <link rel="stylesheet" href="/custom_web/static/src/css/tugas_mahasiswa.css"/>
                <link rel="stylesheet" href="/custom_web/static/src/css/shop.css"/>
                <link rel="stylesheet" href="/custom_web/static/src/css/leaderboard.css"/>
                <script src="/custom_web/static/src/js/presensi.js" type="text/javascript"></script>
                <script src="/custom_web/static/src/js/tugas_dosen.js" type="text/javascript"></script>
                <script src="/custom_web/static/src/js/tugas_mahasiswa.js" type="text/javascript"></script>
                <script src="/custom_web/static/src/js/shop.js" type="text/javascript"></script>
            </head>
            <body>
                <div class="app-container">
                    <div class="sidebar">
                        <div class="sidebar-header">
                            <h3><i class="bi bi-mortarboard-fill" style="color: #3b82f6;"></i> Portal</h3>
                            <div class="user-name">
                                <t t-if="request.session.get('dosen_id')">
                                    <t t-esc="request.session.get('dosen_name', 'Dosen')"/>
                                </t>
                                <t t-else="">
                                    <t t-esc="request.session.get('mahasiswa_name', 'Student')"/>
                                </t>
                            </div>
                        </div>
                        
                        <t t-if="request.session.get('dosen_id')">
                            <ul class="sidebar-nav">
                                <li><a href="/dashboard" t-att-class="'active' if request.httprequest.path.startswith('/dashboard') else ''"><span class="icon"><i class="bi bi-house-door-fill"></i></span> Home</a></li>
                                <li><a href="/dosen/presensi" t-att-class="'active' if request.httprequest.path == '/dosen/presensi' else ''"><span class="icon"><i class="bi bi-calendar-check-fill"></i></span> Presensi Mahasiswa</a></li>
                                <li><a href="/dosen/tugas" t-att-class="'active' if request.httprequest.path == '/dosen/tugas' else ''"><span class="icon"><i class="bi bi-journal-text"></i></span> Tugas</a></li>
                                <li><a href="/dosen/leaderboard" t-att-class="'active' if request.httprequest.path == '/dosen/leaderboard' else ''"><span class="icon"><i class="bi bi-trophy-fill"></i></span> Leaderboard</a></li>
                            </ul>
                        </t>

                        <t t-else="">
                            <ul class="sidebar-nav">
                                <li><a href="/dashboard" t-att-class="'active' if request.httprequest.path.startswith('/dashboard') else ''"><span class="icon"><i class="bi bi-house-door-fill"></i></span> Home</a></li>
                                <li><a href="/presensi" t-att-class="'active' if request.httprequest.path == '/presensi' else ''"><span class="icon"><i class="bi bi-calendar-check-fill"></i></span> Presensi</a></li>
                                <li><a href="/menu" t-att-class="'active' if request.httprequest.path == '/menu' else ''"><span class="icon"><i class="bi bi-clipboard-data-fill"></i></span> Tugas</a></li>
                                <li><a href="/leaderboard" t-att-class="'active' if request.httprequest.path == '/leaderboard' else ''"><span class="icon"><i class="bi bi-trophy-fill"></i></span> Leaderboard</a></li>
                            </ul>
                        </t>
                        <div class="sidebar-footer">
                            <a href="/logout"><span class="icon"><i class="bi bi-box-arrow-right"></i></span> Logout</a>
                        </div>
                    </div>
                    <div class="main-content">
                        <t t-raw="0"/>
                    </div>
                </div>
            </body>
        </html>
    </template>
</odoo>