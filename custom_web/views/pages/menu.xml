<odoo>
    <!-- Rebuild menu template into the Student Tugas Portal -->
    <template id="menu" name="Student Tugas Dashboard">
        <t t-call="custom_web.layout">
            <div class="mhs-tugas-container">
                
                <!-- Simple Header Card -->
                <div class="mhs-header-hud">
                    <div class="hud-profile-meta">
                        <h2>Tugas</h2>
                    </div>
                    <div class="avatar-circle-header">
                        <t t-if="mahasiswa and mahasiswa.foto_profil">
                            <img t-att-src="'data:image/png;base64,' + mahasiswa.foto_profil.decode('utf-8')" alt="Profile" class="avatar-img-round"/>
                        </t>
                        <t t-else="">
                            <span class="avatar-shortcut"><i class="bi bi-person-fill"></i></span>
                        </t>
                    </div>
                </div>

                <!-- Glassmorphic Stats Panel Capsules -->
                <div class="tugas-stats-capsules">
                    <div class="stat-capsule">
                        <span class="icon-side purple"><i class="bi bi-journal-bookmark-fill"></i></span>
                        <div class="stat-info">
                            <span class="num" id="stats-active-count">2</span>
                            <span class="lbl">Tugas Aktif</span>
                        </div>
                    </div>
                    <div class="stat-capsule">
                        <span class="icon-side green"><i class="bi bi-check-circle-fill"></i></span>
                        <div class="stat-info">
                            <span class="num" id="stats-history-count">5</span>
                            <span class="lbl">Selesai</span>
                        </div>
                    </div>
                    <div class="stat-capsule">
                        <span class="icon-side gold"><i class="bi bi-trophy-fill"></i></span>
                        <div class="stat-info">
                            <span class="num">+15 XP</span>
                            <span class="lbl">Reward Min.</span>
                        </div>
                    </div>
                </div>

                <!-- Tabs: Tugas & History -->
                <div class="tugas-tab-filters-layout">
                    <button class="tab-btn active" id="tab-tugas" onclick="switchTugasTab('tugas')">Tugas</button>
                    <button class="tab-btn" id="tab-history" onclick="switchTugasTab('history')">History</button>
                </div>

                <!-- Symmetrical Sided Dashboard Filter & Sort Controls Bar -->
                <div class="dashboard-controls-bar">
                    
                    <!-- Course Filter Dropdown -->
                    <div class="control-box course-select">
                        <label class="dropdown-label">Pilih mata kuliah</label>
                        <div class="course-dropdown-trigger" id="student_course_btn">
                            <span id="selected_student_course">Semua Mata Kuliah</span>
                            <i class="bi bi-chevron-down"></i>
                        </div>
                        <div class="course-dropdown-pane hidden" id="student_course_dropdown">
                            <div class="dropdown-option-item active" data-id="all">Semua Mata Kuliah</div>
                            <t t-foreach="courses" t-as="c">
                                <div class="dropdown-option-item" t-att-data-id="c.id" t-att-data-name="c.nama">
                                    <t t-esc="c.nama"/>
                                </div>
                            </t>
                        </div>
                    </div>

                    <!-- Sort & Status Filter Dropdown -->
                    <div class="control-box sort-select">
                        <label class="dropdown-label">Urutkan &amp; Filter</label>
                        <div class="sort-dropdown-trigger" id="student_sort_btn">
                            <span id="selected_student_sort"><i class="bi bi-funnel-fill text-purple"></i> Urutkan &amp; Filter</span>
                            <i class="bi bi-chevron-down"></i>
                        </div>
                        <div class="sort-dropdown-pane hidden" id="student_sort_dropdown">
                            <div class="sort-option-item active" data-sort="default">Default</div>
                            
                            <div class="dropdown-section-divider">Urutkan Nama &amp; Waktu</div>
                            <div class="sort-option-item" data-sort="name-asc"><i class="bi bi-sort-alpha-down"></i> Nama (A-Z)</div>
                            <div class="sort-option-item" data-sort="name-desc"><i class="bi bi-sort-alpha-up"></i> Nama (Z-A)</div>
                            <div class="sort-option-item" data-sort="date-open-asc"><i class="bi bi-calendar-plus"></i> Tanggal Buka (Terlama)</div>
                            <div class="sort-option-item" data-sort="date-open-desc"><i class="bi bi-calendar-plus-fill"></i> Tanggal Buka (Terbaru)</div>
                            <div class="sort-option-item" data-sort="date-close-asc"><i class="bi bi-calendar-minus"></i> Batas Waktu (Terdekat)</div>
                            <div class="sort-option-item" data-sort="date-close-desc"><i class="bi bi-calendar-minus-fill"></i> Batas Waktu (Terlama)</div>
                            
                            <div class="dropdown-section-divider">Filter Status</div>
                            <div class="sort-option-item" data-sort="filter-all"><i class="bi bi-circle"></i> Semua Status</div>
                            <div class="sort-option-item" data-sort="filter-selesai"><i class="bi bi-check-circle-fill text-success"></i> Selesai</div>
                            <div class="sort-option-item" data-sort="filter-terlambat"><i class="bi bi-exclamation-circle-fill text-danger"></i> Terlambat</div>
                        </div>
                    </div>

                </div>

                <!-- TAB CONTENT 1: Active Tasks (Tugas Tab) -->
                <div id="active-tasks-container" class="tasks-tab-content-wrapper">
                    <div class="mhs-assignments-feed-layout">
                        
                        <!-- Card 1 (Pending) -->
                        <div class="tugas-card-layout" data-id="task-1" data-course-id="6" data-status="pending" data-name="Praktikum 4 DNS Server" data-date-open="2026-05-10" data-date-close="2026-05-15">
                            <div class="card-badge-row">
                                <span class="badge-tag type-individu"><i class="bi bi-person-fill"></i> Individu</span>
                                <span class="badge-tag points-badge"><i class="bi bi-lightning-fill"></i> +15 XP</span>
                            </div>
                            <div class="card-main-content">
                                <h3 class="task-title">Praktikum 4 DNS Server</h3>
                                <p class="task-subject">Administrasi sistem</p>
                                
                                <!-- Start Date and Deadline Timeline -->
                                <div class="task-timeline-dates">
                                    <div class="date-milestone start">
                                        <i class="bi bi-calendar-event"></i>
                                        <div class="m-txt">
                                            <span class="lbl">Tanggal Buka</span>
                                            <span class="val">10 Mei 2026, 08:00 WIB</span>
                                        </div>
                                    </div>
                                    <div class="timeline-connector"></div>
                                    <div class="date-milestone end soon">
                                        <i class="bi bi-calendar-check-fill"></i>
                                        <div class="m-txt">
                                            <span class="lbl">Batas Deadline</span>
                                            <span class="val">15 Mei 2026, 23:59 WIB</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="card-action-buttons">
                                <button type="button" class="btn-detail-task" onclick="showTaskDetails('task-1', 'Praktikum 4 DNS Server', 'Administrasi sistem', 'Buatlah rancangan dan konfigurasi DNS Server master-slave pada linux Debian 12. Laporkan konfigurasi bind9, db.local, dan reverse zone beserta screenshot uji nslookup.')">Detail</button>
                                <button type="button" class="btn-kerjakan-task" onclick="openSubmissionDrawer('task-1', 'Praktikum 4 DNS Server', 'Administrasi sistem')">Kerjakan</button>
                            </div>
                        </div>

                        <!-- Card 2 (Pending) -->
                        <div class="tugas-card-layout" data-id="task-2" data-course-id="5" data-status="pending" data-name="Implementasi Jaringan Saraf Tiruan" data-date-open="2026-05-25" data-date-close="2026-06-03">
                            <div class="card-badge-row">
                                <span class="badge-tag type-kelompok"><i class="bi bi-people-fill"></i> Kelompok</span>
                                <span class="badge-tag points-badge"><i class="bi bi-lightning-fill"></i> +25 XP</span>
                            </div>
                            <div class="card-main-content">
                                <h3 class="task-title">Implementasi Jaringan Saraf Tiruan</h3>
                                <p class="task-subject">Kecerdasan Buatan (AI)</p>
                                
                                <!-- Start Date and Deadline Timeline -->
                                <div class="task-timeline-dates">
                                    <div class="date-milestone start">
                                        <i class="bi bi-calendar-event"></i>
                                        <div class="m-txt">
                                            <span class="lbl">Tanggal Buka</span>
                                            <span class="val">25 Mei 2026, 08:00 WIB</span>
                                        </div>
                                    </div>
                                    <div class="timeline-connector"></div>
                                    <div class="date-milestone end">
                                        <i class="bi bi-calendar-check-fill"></i>
                                        <div class="m-txt">
                                            <span class="lbl">Batas Deadline</span>
                                            <span class="val">3 Juni 2026, 23:59 WIB</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="card-action-buttons">
                                <button type="button" class="btn-detail-task" onclick="showTaskDetails('task-2', 'Implementasi Jaringan Saraf Tiruan', 'Kecerdasan Buatan (AI)', 'Bangun arsitektur multilayer perceptron dengan algoritma backpropagation dari awal menggunakan numpy untuk memprediksi data sensor cuaca.')">Detail</button>
                                <button type="button" class="btn-kerjakan-task" onclick="openSubmissionDrawer('task-2', 'Implementasi Jaringan Saraf Tiruan', 'Kecerdasan Buatan (AI)')">Kerjakan</button>
                            </div>
                        </div>

                    </div>
                </div>

                <!-- TAB CONTENT 2: Premium History Activity Cards Feed -->
                <div id="history-tasks-container" class="tasks-tab-content-wrapper hidden">
                    <div class="history-cards-feed-wrapper">
                        
                        <!-- Row 1: Selesai -->
                        <div class="history-card-strip" data-course-id="6" data-status="completed" data-name="Praktikum 4 DNS Server" data-date-open="2026-05-10" data-date-close="2026-05-15">
                            <div class="strip-info">
                                <h4 class="strip-title">Praktikum 4 DNS Server</h4>
                                <p class="strip-subject">Administrasi sistem</p>
                            </div>
                            <div class="strip-dates">
                                <div class="date-block">
                                    <span class="lbl">Tanggal Buka</span>
                                    <span class="val">10 Mei 2026</span>
                                </div>
                                <div class="date-block">
                                    <span class="lbl">Batas Waktu</span>
                                    <span class="val">15 Mei 2026</span>
                                </div>
                            </div>
                            <div class="strip-badge-side">
                                <span class="badge-status-pill success"><i class="bi bi-patch-check-fill"></i> Selesai</span>
                            </div>
                        </div>

                        <!-- Row 2: Tidak Selesai (Late/Missed) -->
                        <div class="history-card-strip" data-course-id="5" data-status="missed" data-name="Implementasi Neural Network" data-date-open="2026-05-25" data-date-close="2026-06-03">
                            <div class="strip-info">
                                <h4 class="strip-title">Implementasi Neural Network</h4>
                                <p class="strip-subject">Kecerdasan Buatan (AI)</p>
                            </div>
                            <div class="strip-dates">
                                <div class="date-block">
                                    <span class="lbl">Tanggal Buka</span>
                                    <span class="val">25 Mei 2026</span>
                                </div>
                                <div class="date-block">
                                    <span class="lbl">Batas Waktu</span>
                                    <span class="val">3 Juni 2026</span>
                                </div>
                            </div>
                            <div class="strip-badge-side">
                                <span class="badge-status-pill fail"><i class="bi bi-exclamation-triangle-fill"></i> Terlambat</span>
                            </div>
                        </div>

                        <!-- Row 3: Selesai -->
                        <div class="history-card-strip" data-course-id="6" data-status="completed" data-name="Konfigurasi DHCP Server" data-date-open="2026-05-01" data-date-close="2026-05-06">
                            <div class="strip-info">
                                <h4 class="strip-title">Konfigurasi DHCP Server</h4>
                                <p class="strip-subject">Administrasi sistem</p>
                            </div>
                            <div class="strip-dates">
                                <div class="date-block">
                                    <span class="lbl">Tanggal Buka</span>
                                    <span class="val">1 Mei 2026</span>
                                </div>
                                <div class="date-block">
                                    <span class="lbl">Batas Waktu</span>
                                    <span class="val">6 Mei 2026</span>
                                </div>
                            </div>
                            <div class="strip-badge-side">
                                <span class="badge-status-pill success"><i class="bi bi-patch-check-fill"></i> Selesai</span>
                            </div>
                        </div>

                        <!-- Row 4: Tidak Selesai -->
                        <div class="history-card-strip" data-course-id="7" data-status="missed" data-name="Pembuatan REST API Python" data-date-open="2026-05-12" data-date-close="2026-05-18">
                            <div class="strip-info">
                                <h4 class="strip-title">Pembuatan REST API Python</h4>
                                <p class="strip-subject">Pemrograman Web II</p>
                            </div>
                            <div class="strip-dates">
                                <div class="date-block">
                                    <span class="lbl">Tanggal Buka</span>
                                    <span class="val">12 Mei 2026</span>
                                </div>
                                <div class="date-block">
                                    <span class="lbl">Batas Waktu</span>
                                    <span class="val">18 Mei 2026</span>
                                </div>
                            </div>
                            <div class="strip-badge-side">
                                <span class="badge-status-pill fail"><i class="bi bi-exclamation-triangle-fill"></i> Terlambat</span>
                            </div>
                        </div>

                        <!-- Row 5: Selesai -->
                        <div class="history-card-strip" data-course-id="8" data-status="completed" data-name="Perancangan Basis Data" data-date-open="2026-04-15" data-date-close="2026-04-22">
                            <div class="strip-info">
                                <h4 class="strip-title">Perancangan Basis Data</h4>
                                <p class="strip-subject">Basis Data Lanjut</p>
                            </div>
                            <div class="strip-dates">
                                <div class="date-block">
                                    <span class="lbl">Tanggal Buka</span>
                                    <span class="val">15 April 2026</span>
                                </div>
                                <div class="date-block">
                                    <span class="lbl">Batas Waktu</span>
                                    <span class="val">22 April 2026</span>
                                </div>
                            </div>
                            <div class="strip-badge-side">
                                <span class="badge-status-pill success"><i class="bi bi-patch-check-fill"></i> Selesai</span>
                            </div>
                        </div>

                    </div>
                </div>

            </div>

            <!-- Slide-up Submission Drawer / Modal -->
            <div class="submission-modal-overlay" id="submission-overlay" onclick="closeSubmissionDrawer()">
                <div class="submission-drawer" onclick="event.stopPropagation()">
                    <div class="drawer-header">
                        <div class="header-txt">
                            <span class="drawer-icon"><i class="bi bi-cloud-arrow-up-fill"></i></span>
                            <div>
                                <h3 id="submit-task-title">Judul Tugas</h3>
                                <p id="submit-task-subject">Nama Mata Kuliah</p>
                            </div>
                        </div>
                        <button class="btn-close-drawer" onclick="closeSubmissionDrawer()"><i class="bi bi-x-lg"></i></button>
                    </div>
                    <form id="form-kumpul-tugas" class="drawer-form" onsubmit="return false;">
                        <input type="hidden" id="submit-task-id" name="task_id"/>
                        
                        <!-- Upload File Mock Area -->
                        <div class="form-group">
                            <label>Unggah Berkas Tugas (Mock File)</label>
                            <div class="drop-zone" id="drop-zone" onclick="document.getElementById('file-upload').click()">
                                <i class="bi bi-file-earmark-zip-fill text-purple"></i>
                                <p class="drop-main">Tarik &amp; lepas berkas di sini atau klik untuk mencari</p>
                                <p class="drop-sub">Mendukung format ZIP, RAR, PDF, atau DOCX (Maksimal 10MB)</p>
                                <span id="file-name-display" class="file-chosen-name hidden"></span>
                                <input type="file" id="file-upload" class="hidden" onchange="handleFileSelect(this)"/>
                            </div>
                        </div>

                        <!-- Link Submission -->
                        <div class="form-group">
                            <label for="link-submission"><i class="bi bi-link-45deg"></i> Link Tautan Pengumpulan (Opsional)</label>
                            <input type="url" id="link-submission" class="form-control" placeholder="Contoh: https://github.com/username/repository-tugas"/>
                            <p class="input-helper">Sertakan tautan repository GitHub atau Google Drive jika pengerjaan menggunakan kontrol versi.</p>
                        </div>

                        <!-- Catatan Mahasiswa -->
                        <div class="form-group">
                            <label for="catatan">Catatan untuk Dosen</label>
                            <textarea id="catatan" class="form-control" rows="3" placeholder="Tuliskan catatan pengerjaan tambahan di sini..."></textarea>
                        </div>

                        <button type="button" class="btn-submit-drawer" onclick="submitMockSubmission()">
                            <i class="bi bi-check-circle-fill"></i> Kirim &amp; Kumpulkan Jawaban
                        </button>
                    </form>
                </div>
            </div>

            <!-- Task Detail Drawer (Slide up Modal) -->
            <div class="submission-modal-overlay" id="detail-overlay" onclick="closeDetailDrawer()">
                <div class="submission-drawer" onclick="event.stopPropagation()">
                    <div class="drawer-header">
                        <div class="header-txt">
                            <span class="drawer-icon"><i class="bi bi-info-circle-fill"></i></span>
                            <div>
                                <h3 id="detail-task-title">Detail Tugas</h3>
                                <p id="detail-task-subject">Nama Mata Kuliah</p>
                            </div>
                        </div>
                        <button class="btn-close-drawer" onclick="closeDetailDrawer()"><i class="bi bi-x-lg"></i></button>
                    </div>
                    <div class="detail-drawer-body">
                        <label class="desc-label">Deskripsi Instruksi Pengerjaan:</label>
                        <p id="detail-task-desc" class="desc-content"></p>
                    </div>
                </div>
            </div>

            <!-- Celebration POP-UP (Confetti / XP Reward Panel) -->
            <div class="celebration-overlay hidden" id="celebration-panel">
                <div class="celebration-card">
                    <div class="check-circle"><i class="bi bi-check-lg"></i></div>
                    <h3>Tugas Berhasil Dikumpulkan!</h3>
                    <p class="congrats">Luar biasa! Tugas Anda telah tersimpan secara aman di sistem.</p>
                    
                    <!-- Reward HUD -->
                    <div class="gamified-reward">
                        <div class="reward-box xp">
                            <span class="value">+15</span>
                            <span class="label">XP Didapat</span>
                        </div>
                        <div class="reward-box coin">
                            <span class="value">+3</span>
                            <span class="label">Koin Didapat</span>
                        </div>
                    </div>

                    <button class="btn-close-celebration" onclick="closeCelebration()">
                        Kembali ke Dashboard Tugas
                    </button>
                </div>
            </div>

            <div class="glowing-toast-container" id="mhs-toast-container"></div>
        </t>
    </template>
</odoo>
