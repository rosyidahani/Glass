<odoo>
    <template id="lupa_password" name="Lupa Password">
        <html>
            <head>
                <meta charset="utf-8"/>
                <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no"/>
                <title>Lupa Password - GLASS</title>
                <link rel="stylesheet" href="/custom_web/static/src/css/variables.css?v=14"/>
                <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"/>
                <link rel="stylesheet" href="/custom_web/static/src/css/login.css?v=3"/>
                <link rel="stylesheet" href="/custom_web/static/src/css/lupa_password.css?v=1"/>
            </head>
            <body>
                <div class="content-wrapper">
                    <!-- Header -->
                    <div class="header-section">
                        <div class="logo-animation-container">
                            <div class="ambient-glow"></div>
                            <img src="/custom_web/static/src/img/logo.png" alt="GLASS Logo" class="header-logo"/>
                        </div>
                        <div class="header-title">GLASS</div>
                        <div class="header-subtitle">Gamified Learning Attendance and Student System</div>
                    </div>

                    <!-- Card -->
                    <div class="login-card fp-card">

                        <!-- Step Indicator -->
                        <div class="fp-steps">
                            <div class="fp-step active" id="step-dot-1">
                                <div class="fp-step-circle">1</div>
                                <span class="fp-step-label">Email</span>
                            </div>
                            <div class="fp-step-line" id="step-line-1"></div>
                            <div class="fp-step" id="step-dot-2">
                                <div class="fp-step-circle">2</div>
                                <span class="fp-step-label">Verifikasi</span>
                            </div>
                            <div class="fp-step-line" id="step-line-2"></div>
                            <div class="fp-step" id="step-dot-3">
                                <div class="fp-step-circle">3</div>
                                <span class="fp-step-label">Selesai</span>
                            </div>
                        </div>

                        <!-- STEP 1: Input Email -->
                        <div id="fp-step-1" class="fp-panel">
                            <div class="fp-icon-wrapper">
                                <div class="fp-icon-circle">
                                    <i class="bi bi-envelope-fill"></i>
                                </div>
                            </div>
                            <h2 class="fp-title">Lupa Password?</h2>
                            <p class="fp-subtitle">Masukkan email yang terdaftar. Kami akan mengirimkan kode verifikasi OTP untuk mengatur ulang password Anda.</p>

                            <t t-if="error and (not step or step == 1)">
                                <div class="fp-alert-error">
                                    <i class="bi bi-exclamation-triangle-fill"></i>
                                    <t t-esc="error"/>
                                </div>
                            </t>

                            <form id="fpForm" class="modern-form" action="/lupa-password" method="post">
                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                <div class="form-group fp-form-group">
                                    <label for="fp_email" class="fp-label">
                                        <i class="bi bi-envelope-fill"></i> Alamat Email
                                    </label>
                                    <input
                                        type="email"
                                        id="fp_email"
                                        name="email"
                                        placeholder="contoh@email.com"
                                        required="required"
                                        class="form-control fp-input"
                                        autocomplete="email"
                                        t-att-value="email or ''"
                                    />
                                    <span class="fp-input-hint">Gunakan email yang terdaftar sebagai mahasiswa atau dosen.</span>
                                </div>
                                <button type="submit" id="fpSubmitBtn" class="btn-login fp-submit-btn">
                                    <i class="bi bi-send-fill"></i> Kirim Kode OTP
                                </button>
                            </form>

                            <div class="fp-back-link">
                                <a href="/login"><i class="bi bi-arrow-left"></i> Kembali ke Halaman Login</a>
                            </div>
                        </div>

                        <!-- STEP 2: Verifikasi OTP -->
                        <div id="fp-step-2" class="fp-panel" style="display:none;">
                            <div class="fp-icon-wrapper">
                                <div class="fp-icon-circle">
                                    <i class="bi bi-shield-lock-fill"></i>
                                </div>
                            </div>
                            <h2 class="fp-title">Verifikasi Kode OTP</h2>
                            <p class="fp-subtitle">Kami telah mengirimkan 6 digit kode OTP ke email Anda <strong class="text-primary font-weight-bold"><t t-esc="email"/></strong>.</p>

                            <t t-if="error and step == 2">
                                <div class="fp-alert-error">
                                    <i class="bi bi-exclamation-triangle-fill"></i>
                                    <t t-esc="error"/>
                                </div>
                            </t>

                            <form id="otpForm" class="modern-form" action="/lupa-password/verify-otp" method="post">
                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                <div class="form-group fp-form-group">
                                    <label class="fp-label justify-content-center">
                                        Masukkan Kode OTP
                                    </label>
                                    <div class="otp-inputs">
                                        <input type="text" class="otp-digit" maxlength="1" pattern="[0-9]*" inputmode="numeric" required="required" autocomplete="off"/>
                                        <input type="text" class="otp-digit" maxlength="1" pattern="[0-9]*" inputmode="numeric" required="required" autocomplete="off"/>
                                        <input type="text" class="otp-digit" maxlength="1" pattern="[0-9]*" inputmode="numeric" required="required" autocomplete="off"/>
                                        <input type="text" class="otp-digit" maxlength="1" pattern="[0-9]*" inputmode="numeric" required="required" autocomplete="off"/>
                                        <input type="text" class="otp-digit" maxlength="1" pattern="[0-9]*" inputmode="numeric" required="required" autocomplete="off"/>
                                        <input type="text" class="otp-digit" maxlength="1" pattern="[0-9]*" inputmode="numeric" required="required" autocomplete="off"/>
                                    </div>
                                    <!-- Gabungan OTP dimasukkan ke input ini via JS -->
                                    <input type="hidden" name="otp_code" id="otp_code"/>
                                </div>

                                <div class="otp-resend-container">
                                    <span id="otp-timer-text">Kirim ulang kode dalam <strong id="otp-countdown">60</strong> detik</span>
                                    <button type="button" id="otpResendBtn" class="otp-resend-btn" style="display:none;" onclick="resendOTP()">Kirim Ulang OTP</button>
                                </div>

                                <button type="submit" id="otpSubmitBtn" class="btn-login fp-submit-btn">
                                    <i class="bi bi-patch-check-fill"></i> Verifikasi OTP
                                </button>
                            </form>

                            <div class="fp-back-link">
                                <a href="/lupa-password"><i class="bi bi-arrow-left"></i> Kembali ke Pengisian Email</a>
                            </div>
                        </div>

                        <!-- STEP 3: Reset Password Baru -->
                        <div id="fp-step-3" class="fp-panel" style="display:none;">
                            <div class="fp-icon-wrapper">
                                <div class="fp-icon-circle">
                                    <i class="bi bi-key-fill"></i>
                                </div>
                            </div>
                            <h2 class="fp-title">Reset Password</h2>
                            <p class="fp-subtitle">Buat password baru yang aman untuk akun Anda.</p>

                            <t t-if="error and step == 3">
                                <div class="fp-alert-error">
                                    <i class="bi bi-exclamation-triangle-fill"></i>
                                    <t t-esc="error"/>
                                </div>
                            </t>

                            <form id="resetForm" class="modern-form" action="/lupa-password/reset" method="post">
                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                
                                <div class="form-group fp-form-group">
                                    <label for="new_password" class="fp-label">
                                        <i class="bi bi-lock-fill"></i> Password Baru
                                    </label>
                                    <input
                                        type="password"
                                        id="new_password"
                                        name="password"
                                        placeholder="Minimal 6 karakter"
                                        required="required"
                                        class="form-control fp-input"
                                    />
                                </div>

                                <div class="form-group fp-form-group">
                                    <label for="confirm_password" class="fp-label">
                                        <i class="bi bi-check-circle-fill"></i> Konfirmasi Password Baru
                                    </label>
                                    <input
                                        type="password"
                                        id="confirm_password"
                                        name="confirm_password"
                                        placeholder="Konfirmasi password baru"
                                        required="required"
                                        class="form-control fp-input"
                                    />
                                </div>

                                <button type="submit" id="resetSubmitBtn" class="btn-login fp-submit-btn">
                                    <i class="bi bi-check-all"></i> Simpan Password Baru
                                </button>
                            </form>
                        </div>

                        <!-- STEP 4: Selesai -->
                        <div id="fp-step-4" class="fp-panel" style="display:none;">
                            <div class="fp-icon-wrapper">
                                <div class="fp-icon-circle success-icon">
                                    <i class="bi bi-check-circle-fill"></i>
                                </div>
                            </div>
                            <h2 class="fp-title">Password Diperbarui!</h2>
                            <p class="fp-subtitle">Selamat! Password Anda telah berhasil diperbarui. Silakan gunakan password baru untuk masuk ke portal.</p>

                            <a href="/login" class="btn-login fp-submit-btn" style="text-decoration:none;">
                                <i class="bi bi-box-arrow-in-right"></i> Masuk Sekarang
                            </a>
                        </div>

                        <!-- Javascript untuk navigasi step otomatis dari server -->
                        <script type="text/javascript">
                            document.addEventListener('DOMContentLoaded', function() {
                                var step = <t t-esc="step or 1"/>;
                                showFpStep(step);
                            });
                        </script>

                    </div>
                </div>

                <script src="/custom_web/static/src/js/lupa_password.js?v=1" type="text/javascript"></script>
            </body>
        </html>
    </template>
</odoo>
