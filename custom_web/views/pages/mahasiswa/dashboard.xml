<odoo>
    <template id="dashboard" name="Dashboard Page">
        <t t-call="custom_web.layout">
            <link rel="stylesheet" href="/custom_web/static/src/css/dashboard.css"/>

            <div class="dashboard-container">
                <!-- TOP HUD -->
                <div class="top-hud">
                    <div class="hud-left">
                        <!-- Profile Card without EXP -->
                        <a href="/dashboard/mahasiswa/profile" class="profile-pill glass-panel">
                            <div class="avatar-large">
                                <t t-if="mahasiswa.foto_profil">
                                    <img t-att-src="'data:image/png;base64,' + mahasiswa.foto_profil.decode('utf-8')" alt="Profile"/>
                                </t>
                                <t t-else="">
                                    <t t-esc="mahasiswa.name[0].upper()"/>
                                </t>
                            </div>
                            <div class="profile-info">
                                 <div class="profile-name"><t t-esc="mahasiswa.name"/></div>
                                 <div class="profile-level"><t t-esc="mahasiswa.nim"/></div>
                             </div>
                             <!-- Rank Badge on the right inside profile-pill -->
                             <div class="profile-rank-badge" title="Rank Leaderboard">
                                 <span>#<t t-esc="rank"/></span>
                             </div>
                        </a>
                        
                        <!-- Action Buttons stacked below profile pill -->
                        <div class="hud-actions-vertical">
                            <!-- Shop Button -->
                            <a href="/dashboard/mahasiswa/shop" class="icon-btn shop-btn glass-panel" title="Shop">
                                <i class="bi bi-bag-fill"></i>
                            </a>
                            <!-- Setting Button -->
                            <a href="/dashboard/mahasiswa/profile" class="icon-btn setting-btn glass-panel" title="Pengaturan Akun">
                                <i class="bi bi-gear-fill"></i>
                            </a>
                        </div>
                    </div>

                    <!-- Right vertical stack of 2 stats pills -->
                    <div class="hud-right-vertical">
                        <!-- Coin/Poin (Top) -->
                        <div class="coin-pill" title="Koin yang dapat ditukar">
                            <i class="bi bi-coin"></i> <t t-esc="mahasiswa.koin"/> Poin
                        </div>

                        <!-- EXP Pill (Bottom) -->
                        <div class="xp-pill" title="Total XP">
                            <i class="bi bi-star-fill"></i> <t t-esc="mahasiswa.total_xp"/> XP
                        </div>
                    </div>
                </div>

                <!-- MAIN DASHBOARD CONTENT -->
                <div class="main-dashboard-area">
                    
                    <!-- LEFT: 2D Character Area -->
                    <div class="avatar-section glass-panel">
                        <div class="avatar-glow"/>
                        <t t-if="mahasiswa.equipped_avatar_id.is_video">
                            <video t-att-src="mahasiswa.equipped_avatar_id.image_src" class="user-image" autoplay="autoplay" loop="loop" muted="muted" playsinline="playsinline"></video>
                        </t>
                        <t t-else="">
                            <img t-att-src="mahasiswa.equipped_avatar_id.image_src or '/custom_web/static/src/img/char_default.png'" class="user-image" alt="Character Glass"/>
                        </t>
                    </div>

                </div>

            </div>
        </t>
    </template>
</odoo>
