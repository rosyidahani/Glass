<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="leaderboard" name="Leaderboard Mahasiswa">
        <t t-call="custom_web.layout">
            <link rel="stylesheet" href="/custom_web/static/src/css/leaderboard.css"/>

            <!-- Fetch and prepare rank variables safely -->
            <t t-set="rank_1" t-value="students[0] if len(students) &gt; 0 else False"/>
            <t t-set="rank_2" t-value="students[1] if len(students) &gt; 1 else False"/>
            <t t-set="rank_3" t-value="students[2] if len(students) &gt; 2 else False"/>

            <div class="leaderboard-container">
                <!-- Header Topbar -->
                <div class="leaderboard-topbar glass-panel">
                    <a href="/dashboard/mahasiswa" class="back-btn"><i class="bi bi-arrow-left"></i></a>
                    <div class="topbar-title">Leaderboard</div>
                    
                    <div class="topbar-right">
                        <!-- Student XP info pill -->
                        <div class="xp-display" title="Poin XP Anda saat ini">
                            <i class="bi bi-star-fill text-warning me-1"></i> <t t-esc="mahasiswa.total_xp"/> XP
                        </div>
                        <!-- Profile Image -->
                        <div class="topbar-profile">
                            <t t-if="mahasiswa.foto_profil">
                                <img t-att-src="'data:image/png;base64,' + mahasiswa.foto_profil.decode('utf-8')" alt="Profile"/>
                            </t>
                            <t t-else="">
                                <t t-esc="mahasiswa.name[0].upper()"/>
                            </t>
                        </div>
                    </div>
                </div>

                <!-- Section 1: Podium Top 3 -->
                <div class="podium-section glass-panel">
                    <div class="podium-row-wrapper">
                        
                        <!-- Rank 2 Podium (Left) -->
                        <t t-if="rank_2">
                            <div t-attf-class="podium-card rank-2 #{'highlight' if rank_2.id == mahasiswa.id else ''}">
                                <div class="podium-bar bar-silver">
                                    <!-- 4-Pointed Star Flare Heads (2 heads) -->
                                    <div class="comet-head-star head-1 head-silver"></div>
                                    <div class="comet-head-star head-2 head-silver"></div>

                                    <!-- Trailing Star Dust Particles (12 particles for long connected tails) -->
                                    <div class="comet-particle p1 part-silver"></div>
                                    <div class="comet-particle p2 part-silver"></div>
                                    <div class="comet-particle p3 part-silver"></div>
                                    <div class="comet-particle p4 part-silver"></div>
                                    <div class="comet-particle p5 part-silver"></div>
                                    <div class="comet-particle p6 part-silver"></div>
                                    <div class="comet-particle p7 part-silver"></div>
                                    <div class="comet-particle p8 part-silver"></div>
                                    <div class="comet-particle p9 part-silver"></div>
                                    <div class="comet-particle p10 part-silver"></div>
                                    <div class="comet-particle p11 part-silver"></div>
                                    <div class="comet-particle p12 part-silver"></div>
                                    
                                    <!-- Inner Bar Content -->
                                    <div class="podium-bar-content content-silver">
                                        <div class="podium-avatar-container">
                                            <img t-att-src="rank_2.equipped_avatar_id.avatar_id.image_src or '/custom_web/static/src/img/char_default.png'" alt="Rank 2 Avatar" class="podium-avatar"/>
                                            <div class="podium-badge badge-silver">2</div>
                                        </div>
                                        <div class="podium-name"><t t-esc="rank_2.name"/></div>
                                        <div class="podium-xp"><t t-esc="rank_2.total_xp"/> XP</div>
                                    </div>
                                </div>
                            </div>
                        </t>
                        
                        <!-- Rank 1 Podium (Center) -->
                        <t t-if="rank_1">
                            <div t-attf-class="podium-card rank-1 #{'highlight' if rank_1.id == mahasiswa.id else ''}">
                                <div class="podium-bar bar-gold">
                                    <!-- 4-Pointed Star Flare Heads (2 heads) -->
                                    <div class="comet-head-star head-1 head-gold"></div>
                                    <div class="comet-head-star head-2 head-gold"></div>

                                    <!-- Trailing Star Dust Particles (12 particles for long connected tails) -->
                                    <div class="comet-particle p1 part-gold"></div>
                                    <div class="comet-particle p2 part-gold"></div>
                                    <div class="comet-particle p3 part-gold"></div>
                                    <div class="comet-particle p4 part-gold"></div>
                                    <div class="comet-particle p5 part-gold"></div>
                                    <div class="comet-particle p6 part-gold"></div>
                                    <div class="comet-particle p7 part-gold"></div>
                                    <div class="comet-particle p8 part-gold"></div>
                                    <div class="comet-particle p9 part-gold"></div>
                                    <div class="comet-particle p10 part-gold"></div>
                                    <div class="comet-particle p11 part-gold"></div>
                                    <div class="comet-particle p12 part-gold"></div>

                                    <!-- Inner Bar Content -->
                                    <div class="podium-bar-content content-gold">
                                        <div class="crown-glow">
                                            <i class="bi bi-crown-fill"></i>
                                        </div>
                                        <div class="podium-avatar-container">
                                            <img t-att-src="rank_1.equipped_avatar_id.avatar_id.image_src or '/custom_web/static/src/img/char_default.png'" alt="Rank 1 Avatar" class="podium-avatar"/>
                                            <div class="podium-badge badge-gold">1</div>
                                        </div>
                                        <div class="podium-name"><t t-esc="rank_1.name"/></div>
                                        <div class="podium-xp"><t t-esc="rank_1.total_xp"/> XP</div>
                                    </div>
                                </div>
                            </div>
                        </t>

                        <!-- Rank 3 Podium (Right) -->
                        <t t-if="rank_3">
                            <div t-attf-class="podium-card rank-3 #{'highlight' if rank_3.id == mahasiswa.id else ''}">
                                <div class="podium-bar bar-bronze">
                                    <!-- 4-Pointed Star Flare Heads (2 heads) -->
                                    <div class="comet-head-star head-1 head-bronze"></div>
                                    <div class="comet-head-star head-2 head-bronze"></div>

                                    <!-- Trailing Star Dust Particles (12 particles for long connected tails) -->
                                    <div class="comet-particle p1 part-bronze"></div>
                                    <div class="comet-particle p2 part-bronze"></div>
                                    <div class="comet-particle p3 part-bronze"></div>
                                    <div class="comet-particle p4 part-bronze"></div>
                                    <div class="comet-particle p5 part-bronze"></div>
                                    <div class="comet-particle p6 part-bronze"></div>
                                    <div class="comet-particle p7 part-bronze"></div>
                                    <div class="comet-particle p8 part-bronze"></div>
                                    <div class="comet-particle p9 part-bronze"></div>
                                    <div class="comet-particle p10 part-bronze"></div>
                                    <div class="comet-particle p11 part-bronze"></div>
                                    <div class="comet-particle p12 part-bronze"></div>

                                    <!-- Inner Bar Content -->
                                    <div class="podium-bar-content content-bronze">
                                        <div class="podium-avatar-container">
                                            <img t-att-src="rank_3.equipped_avatar_id.avatar_id.image_src or '/custom_web/static/src/img/char_default.png'" alt="Rank 3 Avatar" class="podium-avatar"/>
                                            <div class="podium-badge badge-bronze">3</div>
                                        </div>
                                        <div class="podium-name"><t t-esc="rank_3.name"/></div>
                                        <div class="podium-xp"><t t-esc="rank_3.total_xp"/> XP</div>
                                    </div>
                                </div>
                            </div>
                        </t>

                    </div>
                </div>

                <!-- Section 2: Remaining Rank List (Rank 4+) -->
                <div class="leaderboard-list-section">
                    <div class="list-header">
                        <div class="list-title">Peringkat Lainnya</div>
                    </div>
                    
                    <div class="leaderboard-rows-container">
                        <t t-set="rank_idx" t-value="4"/>
                        <t t-foreach="students[3:]" t-as="student">
                            <div t-attf-class="leaderboard-row glass-panel #{'current-user-row' if student.id == mahasiswa.id else ''}">
                                <div class="row-rank-num-container">
                                    <span class="row-rank-badge">#<t t-esc="rank_idx"/></span>
                                </div>
                                <div class="row-avatar-box">
                                    <img t-att-src="student.equipped_avatar_id.avatar_id.image_src or '/custom_web/static/src/img/char_default.png'" alt="Student Avatar" class="row-avatar-img"/>
                                </div>
                                <div class="row-student-info">
                                    <div class="row-student-name"><t t-esc="student.name"/></div>
                                    <div class="row-student-nim"><t t-esc="student.nim"/></div>
                                </div>
                                <div class="row-xp-score">
                                    <i class="bi bi-star"></i> <t t-esc="student.total_xp"/> XP
                                </div>
                            </div>
                            <t t-set="rank_idx" t-value="rank_idx + 1"/>
                        </t>
                        <t t-if="len(students) &lt;= 3">
                            <div class="no-more-rank glass-panel">
                                Belum ada peringkat tambahan.
                            </div>
                        </t>
                    </div>
                </div>
            </div>
        </t>
    </template>
</odoo>
