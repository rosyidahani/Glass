<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="profile" name="Mahasiswa Profile">
        <t t-call="custom_web.layout">
            <link rel="stylesheet" href="/custom_web/static/src/css/profile.css"/>

            <div class="profile-container">
                <t t-call="custom_web.shared_student_header">
                    <t t-set="title" t-value="'Profil'"/>
                    <t t-set="back_url" t-value="'/dashboard/mahasiswa'"/>
                </t>

                <!-- Header Section -->
                <div class="profile-header">
                    <div class="profile-picture-wrapper">
                        <div class="profile-picture" onclick="document.getElementById('fotoProfilInput').click();" style="cursor: pointer;" title="Ubah Foto">
                            <t t-if="mahasiswa.foto_profil">
                                <img t-att-src="'data:image/png;base64,' + mahasiswa.foto_profil.decode('utf-8')" alt="Profile"/>
                            </t>
                            <t t-else="">
                                <t t-esc="mahasiswa.name[0].upper()"/>
                            </t>
                        </div>
                        <div class="edit-icon" title="Ubah Foto" onclick="document.getElementById('fotoProfilInput').click();"><i class="bi bi-pencil-fill"></i></div>
                    </div>
                    <div class="profile-details">
                        <h2><t t-esc="mahasiswa.name"/></h2>
                        <p>NIM: <t t-esc="mahasiswa.nim"/></p>
                        <a href="#" class="edit-btn" onclick="document.getElementById('fotoProfilInput').click(); return false;">Edit Photo</a>
                    </div>
                </div>

                <form action="/dashboard/mahasiswa/profile/upload_photo" method="post" enctype="multipart/form-data" id="photoUploadForm" style="display: none;">
                    <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                    <input type="file" name="foto_profil" id="fotoProfilInput" accept="image/png, image/jpeg, image/jpg" onchange="document.getElementById('photoUploadForm').submit();"/>
                </form>

                <!-- Stats Tabs -->
                <div class="stats-container">
                    <div class="stat-box">
                        <h4><t t-esc="mahasiswa.semester"/></h4>
                        <span>Semester</span>
                    </div>
                    <div class="stat-box">
                        <h4><t t-esc="mahasiswa.koin"/></h4>
                        <span>Koin</span>
                    </div>
                    <div class="stat-box">
                        <h4><t t-esc="mahasiswa.total_xp"/></h4>
                        <span>Total XP</span>
                    </div>
                </div>

                <!-- Settings List (Tambahan untuk melengkapi UX) -->
                <div class="settings-list">
                    <a href="#" class="settings-item">
                        <div class="item-left">
                            <div class="item-icon"><i class="bi bi-person-fill"></i></div>
                            <span>Informasi Pribadi</span>
                        </div>
                        <div class="item-arrow"><i class="bi bi-chevron-right"></i></div>
                    </a>
                    <a href="#" class="settings-item">
                        <div class="item-left">
                            <div class="item-icon"><i class="bi bi-shield-lock-fill"></i></div>
                            <span>Keamanan &amp; Password</span>
                        </div>
                        <div class="item-arrow"><i class="bi bi-chevron-right"></i></div>
                    </a>
                    <a href="#" class="settings-item">
                        <div class="item-left">
                            <div class="item-icon"><i class="bi bi-bell-fill"></i></div>
                            <span>Pengaturan Notifikasi</span>
                        </div>
                        <div class="item-arrow"><i class="bi bi-chevron-right"></i></div>
                    </a>
                </div>
            </div>
        </t>
    </template>
</odoo>
