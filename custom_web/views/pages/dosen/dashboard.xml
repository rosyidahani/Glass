<odoo>
    <template id="dashboard_dosen" name="Dashboard Dosen">
        <t t-call="custom_web.layout">
            <link rel="stylesheet" href="/custom_web/static/src/css/dosen_dashboard.css?v=11"/>
            
            <div class="dosen-dashboard-container">
                <!-- Lecturer Profile HUD Header -->
                <div class="dosen-header-hud">
                    <div class="dosen-profile-info">
                        <div class="dosen-avatar-wrapper">
                            <t t-esc="dosen.name[0].upper() if dosen and dosen.name else 'D'"/>
                        </div>
                        <div class="dosen-meta">
                            <h2 class="dosen-name"><t t-esc="dosen.name if dosen else 'Dosen'"/></h2>
                            <p class="dosen-role"><i class="bi bi-shield-check"></i> <span data-translate-id="lecturer_portal">Portal Dosen</span> (NIP: <t t-esc="dosen.nip if dosen else 'N/A'"/>)</p>
                        </div>
                    </div>
                    <!-- Settings Button -->
                    <a href="/dashboard/dosen/settings" class="dosen-settings-btn" data-translate-title-id="dash_settings" title="Pengaturan Akun">
                        <i class="bi bi-gear-fill"></i>
                    </a>
                </div>

                <!-- Main Action Cards Layout -->
                <div class="dosen-grid">
                    <!-- CARD 1: Buat Tugas -->
                    <div class="dosen-card glass-panel">
                        <div class="dosen-card-icon icon-blue">
                            <i class="bi bi-file-earmark-plus-fill"></i>
                        </div>
                        <div class="dosen-card-body">
                            <h3 data-translate-id="card_make_task_title">Buat Tugas</h3>
                            <p data-translate-id="card_make_task_desc">Kelola dan buat penugasan baru untuk mahasiswa secara terorganisir.</p>
                        </div>
                        <div class="dosen-card-footer">
                            <a href="/dosen/tugas" class="dosen-action-btn btn-blue" data-translate-id="card_make_task_btn">Kelola Tugas</a>
                        </div>
                    </div>

                    <!-- CARD 2: Presensi -->
                    <div class="dosen-card glass-panel">
                        <div class="dosen-card-icon icon-purple">
                            <i class="bi bi-calendar-check-fill"></i>
                        </div>
                        <div class="dosen-card-body">
                            <h3 data-translate-id="card_attendance_title">Presensi</h3>
                            <p data-translate-id="card_attendance_desc">Buka sesi kehadiran kelas baru dan awasi partisipasi mahasiswa secara instan.</p>
                        </div>
                        <div class="dosen-card-footer">
                            <a href="/dosen/presensi" class="dosen-action-btn btn-purple" data-translate-id="card_attendance_btn">Mulai Presensi</a>
                        </div>
                    </div>

                    <!-- CARD 3: Pengumpulan Tugas -->
                    <div class="dosen-card glass-panel">
                        <div class="dosen-card-icon icon-amber">
                            <i class="bi bi-people-fill"></i>
                        </div>
                        <div class="dosen-card-body">
                            <h3 data-translate-id="card_submission_title">Pengumpulan</h3>
                            <p data-translate-id="card_submission_desc">Periksa berkas jawaban tugas mahasiswa dan berikan feedback nilai secara instan.</p>
                        </div>
                        <div class="dosen-card-footer">
                            <a href="/dosen/tugas/pengumpulan" class="dosen-action-btn btn-amber" data-translate-id="card_submission_btn">Periksa Tugas</a>
                        </div>
                    </div>

                    <!-- CARD 4: Leaderboard Mahasiswa -->
                    <div class="dosen-card glass-panel">
                        <div class="dosen-card-icon icon-emerald">
                            <i class="bi bi-trophy-fill"></i>
                        </div>
                        <div class="dosen-card-body">
                            <h3 data-translate-id="card_leaderboard_title">Leaderboard</h3>
                            <p data-translate-id="card_leaderboard_desc">Pantau peringkat mahasiswa berdasarkan akumulasi XP dan pencapaian mereka.</p>
                        </div>
                        <div class="dosen-card-footer">
                            <a href="/dosen/leaderboard" class="dosen-action-btn btn-emerald" data-translate-id="card_leaderboard_btn">Lihat Peringkat</a>
                        </div>
                    </div>
                </div>

            </div>
        </t>
    </template>
</odoo>
