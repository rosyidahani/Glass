<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="settings_dosen_language" name="Dosen Settings - Bahasa">
        <t t-call="custom_web.layout">
            <link rel="stylesheet" href="/custom_web/static/src/css/settings.css"/>

            <div class="profile-container">
                <div class="profile-header">
                    <div class="profile-picture-wrapper">
                        <t t-if="dosen and dosen.foto_profil">
                            <img t-att-src="'data:image/png;base64,' + dosen.foto_profil.decode('utf-8')" class="profile-picture" style="object-fit: cover;"/>
                        </t>
                        <t t-else="">
                            <img src="/custom_web/static/src/img/avatar_default.png" class="profile-picture" style="object-fit: cover;"/>
                        </t>
                    </div>
                    <div class="profile-details">
                        <h2 data-translate-id="set_lang">Bahasa</h2>
                        <p>NIP: <t t-esc="dosen.nip"/></p>
                    </div>
                </div>

                <div class="settings-list" style="margin-top: 12px;">
                    <form id="form_set_bahasa" class="settings-item" style="margin:0;padding:0;" enctype="multipart/form-data">
                        <div class="settings-item" style="border:none;cursor:default;">
                            <div class="item-left">
                                <div class="item-icon"><i class="bi bi-translate"></i></div>
                                <span data-translate-id="dosen_select_language">Pilih bahasa</span>
                            </div>
                            <div style="display:flex;flex-direction:column;gap:10px;align-items:flex-start;margin-top:10px;">
                                <label><input type="radio" name="bahasa_preference" value="id"/> Bahasa Indonesia</label>
                                <label><input type="radio" name="bahasa_preference" value="en"/> English</label>
                            </div>
                            <div style="margin-top:10px;">
                                <button type="submit" class="btn btn-primary" data-translate-id="dosen_btn_save">Simpan</button>
                            </div>
                        </div>
                    </form>

                    <a href="/dashboard/dosen/settings" class="settings-item">
                        <div class="item-left">
                            <div class="item-icon"><i class="bi bi-arrow-left"></i></div>
                            <span data-translate-id="dosen_btn_back">Kembali</span>
                        </div>
                    </a>

                </div>
            </div>
        </t>
    </template>
</odoo>

