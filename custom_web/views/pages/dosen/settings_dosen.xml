<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="settings_dosen" name="Dosen Settings">
        <t t-call="custom_web.layout">
            <link rel="stylesheet" href="/custom_web/static/src/css/settings.css"/>
            <script src="/custom_web/static/src/js/settings_dosen.js" type="text/javascript"></script>

            <div class="profile-container">
                <t t-call="custom_web.shared_student_header">
                    <t t-set="title" t-value="'Pengaturan'"/>
                    <t t-set="back_url" t-value="'/dashboard/dosen'"/>
                </t>

                <!-- Header Section -->
                <div class="profile-header">
                    <div class="profile-picture-wrapper">
                        <t t-if="dosen.foto_profil">
                            <img t-att-src="'data:image/png;base64,' + dosen.foto_profil.decode('utf-8')" class="profile-picture" style="object-fit: cover; width: 80px; height: 80px; border-radius: 50%; border: 2px solid var(--accent-color);"/>
                        </t>
                        <t t-else="">
                            <div class="profile-picture" style="background: linear-gradient(135deg, #3b82f6, #8b5cf6); width: 80px; height: 80px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 28px; font-weight: 800; color: #fff;">
                                <t t-esc="dosen.name[0].upper()"/>
                            </div>
                        </t>
                    </div>
                    <div class="profile-details">
                        <h2><t t-esc="dosen.name"/></h2>
                        <p>NIP: <t t-esc="dosen.nip"/></p>
                        
                        <!-- Form to upload profile photo -->
                        <form id="form_upload_foto_dosen" style="margin-top: 8px;">
                            <label for="foto_profil_input" class="btn-change-photo" style="background: var(--accent-color); color: white; padding: 6px 12px; border-radius: 8px; font-size: 12px; cursor: pointer; display: inline-flex; align-items: center; gap: 6px; font-weight: 600;">
                                <i class="bi bi-camera-fill"></i> Ubah Foto Profil
                            </label>
                            <input type="file" id="foto_profil_input" accept="image/*" style="display: none;" onchange="document.getElementById('btn_submit_foto_dosen').click();"/>
                            <button type="submit" id="btn_submit_foto_dosen" style="display: none;"></button>
                        </form>
                    </div>
                </div>

                <!-- Stats/Info Container -->
                <div class="stats-container">
                    <div class="stat-box prodi-box">
                        <h4><t t-esc="dosen.prodi or '-'"/></h4>
                        <span>Program Studi</span>
                    </div>
                    <div class="stat-box kepakaran-box">
                        <h4><t t-esc="dosen.spesialisasi or '-'"/></h4>
                        <span>Kepakaran / Keilmuan</span>
                    </div>
                </div>

                <!-- Settings List -->
                <div class="settings-list">
                    <a href="/dashboard/dosen/settings/1" class="settings-item">
                        <div class="item-left">
                            <div class="item-icon"><i class="bi bi-shield-lock-fill"></i></div>
                            <span data-translate-id="set_security">Sandi &amp; Keamanan</span>
                        </div>
                        <div class="item-arrow"><i class="bi bi-chevron-right"></i></div>
                    </a>
                    <a href="/dashboard/dosen/settings/2" class="settings-item">
                        <div class="item-left">
                            <div class="item-icon"><i class="bi bi-palette-fill"></i></div>
                            <span data-translate-id="set_theme">Tema</span>
                        </div>
                        <div class="item-arrow"><i class="bi bi-chevron-right"></i></div>
                    </a>
                    <a href="/dashboard/dosen/settings/3" class="settings-item">
                        <div class="item-left">
                            <div class="item-icon"><i class="bi bi-translate"></i></div>
                            <span data-translate-id="set_lang">Bahasa</span>
                        </div>
                        <div class="item-arrow"><i class="bi bi-chevron-right"></i></div>
                    </a>
                    <a href="/logout" class="settings-item logout-item" style="color: #ef4444;">
                        <div class="item-left">
                            <div class="item-icon" style="background: rgba(239, 68, 68, 0.1); color: #ef4444;"><i class="bi bi-box-arrow-right"></i></div>
                            <span data-translate-id="set_logout">Log out</span>
                        </div>
                        <div class="item-arrow" style="color: #ef4444;"><i class="bi bi-chevron-right"></i></div>
                    </a>
                </div>
            </div>
        </t>
    </template>
</odoo>
