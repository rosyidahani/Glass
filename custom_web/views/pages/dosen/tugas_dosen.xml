<odoo>
    
    <!-- 1. TEMPLATE MENU UTAMA TUGAS DOSEN (INTERMEDIATE MENU) -->
    <template id="tugas_dosen_menu" name="Menu Utama Tugas Dosen">
        <t t-call="custom_web.layout">
            <div class="dosen-tugas-container">
                <!-- HUD Header -->
                <div class="dosen-header-hud">
                    <div class="dosen-profile-info">
                        <div class="dosen-avatar-wrapper">
                            <t t-esc="dosen.name[0] if dosen and dosen.name else 'D'"/>
                        </div>
                        <div class="dosen-meta">
                            <h2 class="dosen-name"><t t-esc="dosen.name if dosen else 'Dosen'"/></h2>
                            <p class="dosen-role"><i class="bi bi-shield-check"></i> Portal Tugas Dosen (NIP: <t t-esc="dosen.nip if dosen else 'N/A'"/>)</p>
                        </div>
                    </div>
                    <a href="/dashboard" class="btn-back-dashboard">
                        <i class="bi bi-house-fill"></i> Dashboard Utama
                    </a>
                </div>

                <!-- Intermediate Navigation Cards (Minimalist Widget Tiles) -->
                <div class="dosen-menu-tugas-grid">
                    
                    <!-- Card 1: Buat Tugas Baru -->
                    <a href="/dosen/tugas/buat" class="glass-menu-card purple-glow">
                        <div class="card-glow-bg"></div>
                        <div class="card-icon-circle">
                            <i class="bi bi-journal-plus"></i>
                        </div>
                        <h3>Buat Tugas Baru</h3>
                    </a>

                    <!-- Card 2: Pengumpulan Mahasiswa -->
                    <a href="/dosen/tugas/pengumpulan" class="glass-menu-card blue-glow">
                        <div class="card-glow-bg"></div>
                        <div class="card-icon-circle">
                            <i class="bi bi-people-fill"></i>
                        </div>
                        <h3>Pengumpulan Mahasiswa</h3>
                    </a>

                </div>
            </div>
        </t>
    </template>

    <!-- 2. TEMPLATE BUAT TUGAS BARU (CREATION FORM & FEED) -->
    <template id="tugas_dosen_buat" name="Dosen Buat Tugas">
        <t t-call="custom_web.layout">
            <div class="dosen-tugas-container">
                <!-- HUD Header -->
                <div class="dosen-header-hud">
                    <div class="dosen-profile-info">
                        <div class="dosen-avatar-wrapper">
                            <t t-esc="dosen.name[0] if dosen and dosen.name else 'D'"/>
                        </div>
                        <div class="dosen-meta">
                            <h2 class="dosen-name">Buat &amp; Kelola Tugas</h2>
                            <p class="dosen-role"><i class="bi bi-pencil-square"></i> Buat tugas baru dan kelola daftar tugas aktif Anda</p>
                        </div>
                    </div>
                    <a href="/dosen/tugas" class="btn-back-dashboard">
                        <i class="bi bi-arrow-left"></i> Kembali ke Menu Tugas
                    </a>
                </div>

                <!-- Grid System -->
                <div class="dosen-tugas-grid">
                    <!-- Left: Form Panel -->
                    <div class="glass-panel">
                        <div class="card-header">
                            <span class="header-icon"><i class="bi bi-journal-plus"></i></span>
                            <h3>Buat Tugas Baru</h3>
                        </div>
                        <form id="form-buat-tugas" class="modern-form" onsubmit="return false;">
                            <div class="form-group">
                                <label for="mk_id">Mata Kuliah <span class="required">*</span></label>
                                <select id="mk_id" name="mk_id" class="form-control" required="required">
                                    <option value="" disabled="disabled" selected="selected">-- Pilih Mata Kuliah --</option>
                                    <t t-foreach="mata_kuliah" t-as="mk">
                                        <option t-att-value="mk['id']"><t t-esc="mk['name']"/></option>
                                    </t>
                                </select>
                            </div>

                            <div class="form-group">
                                <label>Jenis Tugas <span class="required">*</span></label>
                                <div class="segmented-control">
                                    <input type="radio" id="jenis_individu" name="jenis_tugas" value="Individu" checked="checked"/>
                                    <label for="jenis_individu" class="segmented-label individu-label">
                                        <i class="bi bi-person-fill"></i> Individu
                                    </label>
                                    <input type="radio" id="jenis_kelompok" name="jenis_tugas" value="Kelompok"/>
                                    <label for="jenis_kelompok" class="segmented-label kelompok-label">
                                        <i class="bi bi-people-fill"></i> Kelompok
                                    </label>
                                </div>
                            </div>

                            <div class="form-group">
                                <label for="judul">Judul Tugas <span class="required">*</span></label>
                                <input type="text" id="judul" name="judul" class="form-control" placeholder="Contoh: Proyek Akhir Web Portal" required="required"/>
                            </div>

                            <div class="form-group">
                                <label for="deadline">Batas Pengumpulan (Deadline) <span class="required">*</span></label>
                                <input type="datetime-local" id="deadline" name="deadline" class="form-control" required="required"/>
                            </div>

                            <div class="form-group">
                                <label for="deskripsi">Deskripsi Tugas <span class="required">*</span></label>
                                <textarea id="deskripsi" name="deskripsi" class="form-control" rows="4" placeholder="Tuliskan petunjuk pengerjaan dan ketentuan tugas di sini..." required="required"></textarea>
                            </div>

                            <button type="submit" class="btn-submit-tugas">
                                <i class="bi bi-send-fill"></i> Simpan &amp; Publikasikan Tugas
                            </button>
                        </form>
                    </div>

                    <!-- Right: List & Stats -->
                    <div class="glass-panel">
                        <div class="card-header">
                            <span class="header-icon"><i class="bi bi-card-checklist"></i></span>
                            <h3>Daftar Tugas Aktif</h3>
                        </div>
                        <div class="tugas-stats-hud">
                            <div class="stat-card total">
                                <span class="num" id="stat-total-tugas">2</span>
                                <span class="lbl">Total Tugas</span>
                            </div>
                            <div class="stat-card individu">
                                <span class="num text-purple" id="stat-individu">1</span>
                                <span class="lbl">Individu</span>
                            </div>
                            <div class="stat-card kelompok">
                                <span class="num text-blue" id="stat-kelompok">1</span>
                                <span class="lbl">Kelompok</span>
                            </div>
                        </div>
                        <div class="assignments-feed" id="assignments-list">
                            <!-- Mock Assignment 1 -->
                            <div class="tugas-item" data-id="mock-1" data-jenis="Individu">
                                <div class="tugas-item-header">
                                    <div class="tugas-title-meta">
                                        <h4>Implementasi Jaringan Saraf Tiruan (Backpropagation)</h4>
                                        <p class="subject"><i class="bi bi-book"></i> Kecerdasan Buatan (AI)</p>
                                    </div>
                                    <span class="type-badge individu">Individu</span>
                                </div>
                                <div class="tugas-item-body">
                                    <span class="val text-danger"><i class="bi bi-clock-fill"></i> 3 Juni 2026, 23:59 WIB</span>
                                    <p class="desc text-truncate-3">Buatlah rancangan dan kode implementasi Jaringan Saraf Tiruan dengan algoritma Backpropagation dari awal tanpa menggunakan framework ML eksternal.</p>
                                </div>
                                <div class="tugas-item-footer">
                                    <button class="btn-toggle-detail" onclick="toggleDetails(this)"><i class="bi bi-chevron-down"></i> Detail</button>
                                    <div class="actions">
                                        <button class="btn-action edit" onclick="editMockTask('mock-1')"><i class="bi bi-pencil-square"></i></button>
                                        <button class="btn-action delete" onclick="deleteMockTask('mock-1')"><i class="bi bi-trash3-fill"></i></button>
                                    </div>
                                </div>
                            </div>
                            <!-- Mock Assignment 2 -->
                            <div class="tugas-item" data-id="mock-2" data-jenis="Kelompok">
                                <div class="tugas-item-header">
                                    <div class="tugas-title-meta">
                                        <h4>Pembangunan Portal Web dengan Odoo Controller</h4>
                                        <p class="subject"><i class="bi bi-book"></i> Pemrograman Web II</p>
                                    </div>
                                    <span class="type-badge kelompok">Kelompok</span>
                                </div>
                                <div class="tugas-item-body">
                                    <span class="val text-danger"><i class="bi bi-clock-fill"></i> 7 Juni 2026, 23:59 WIB</span>
                                    <p class="desc text-truncate-3">Bangunlah sebuah modul Odoo custom yang berisi template website frontend terintegrasi dengan session Odoo backend.</p>
                                </div>
                                <div class="tugas-item-footer">
                                    <button class="btn-toggle-detail" onclick="toggleDetails(this)"><i class="bi bi-chevron-down"></i> Detail</button>
                                    <div class="actions">
                                        <button class="btn-action edit" onclick="editMockTask('mock-2')"><i class="bi bi-pencil-square"></i></button>
                                        <button class="btn-action delete" onclick="deleteMockTask('mock-2')"><i class="bi bi-trash3-fill"></i></button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="glowing-toast-container" id="toast-container"></div>
        </t>
    </template>

    <!-- 3. TEMPLATE PENGUMPULAN MAHASISWA (FILTER LIST & MINIMALIST TITLES ONLY) -->
    <template id="tugas_dosen_pengumpulan" name="Dosen Umpan Balik Tugas">
        <t t-call="custom_web.layout">
            <div class="dosen-tugas-container">
                <!-- HUD Header -->
                <div class="dosen-header-hud">
                    <div class="dosen-profile-info">
                        <div class="dosen-avatar-wrapper">
                            <t t-esc="dosen.name[0] if dosen and dosen.name else 'D'"/>
                        </div>
                        <div class="dosen-meta">
                            <h2 class="dosen-name">Pengumpulan Mahasiswa</h2>
                            <p class="dosen-role"><i class="bi bi-card-checklist"></i> Saring tugas dan periksa hasil jawaban mahasiswa Anda</p>
                        </div>
                    </div>
                    <a href="/dosen/tugas" class="btn-back-dashboard">
                        <i class="bi bi-arrow-left"></i> Kembali ke Menu Tugas
                    </a>
                </div>

                <!-- Course Filter Tabs -->
                <div class="dosen-course-filters">
                    <button class="course-filter-btn active" data-filter="all">
                        <i class="bi bi-grid-fill"></i> Semua Kelas
                    </button>
                    <t t-foreach="mata_kuliah" t-as="mk">
                        <button class="course-filter-btn" t-att-data-filter="mk['id']">
                            <i class="bi bi-book"></i> <t t-esc="mk['name']"/>
                        </button>
                    </t>
                </div>

                <!-- Assignment Cards Feed (Titles Only as requested) -->
                <div class="dosen-submissions-feed-grid" id="submissions-tasks-container">
                    
                    <!-- Task 1 (Kecerdasan Buatan - AI) -->
                    <a href="/dosen/tugas/detail/mock-1" class="dosen-submission-task-card" data-course-id="1">
                        <div class="task-card-header">
                            <span class="badge-tag purple">Kecerdasan Buatan (AI)</span>
                            <span class="badge-tag outline">Individu</span>
                        </div>
                        <h3 class="task-card-title">Implementasi Jaringan Saraf Tiruan (Backpropagation)</h3>
                        <div class="task-card-footer">
                            <span><i class="bi bi-people"></i> 4 Mahasiswa Mengumpulkan</span>
                            <span class="btn-action-detail">Periksa <i class="bi bi-chevron-right"></i></span>
                        </div>
                    </a>

                    <!-- Task 2 (Pemrograman Web II) -->
                    <a href="/dosen/tugas/detail/mock-2" class="dosen-submission-task-card" data-course-id="2">
                        <div class="task-card-header">
                            <span class="badge-tag blue">Pemrograman Web II</span>
                            <span class="badge-tag outline">Kelompok</span>
                        </div>
                        <h3 class="task-card-title">Pembangunan Portal Web dengan Odoo Controller</h3>
                        <div class="task-card-footer">
                            <span><i class="bi bi-people"></i> 3 Kelompok Mengumpulkan</span>
                            <span class="btn-action-detail">Periksa <i class="bi bi-chevron-right"></i></span>
                        </div>
                    </a>

                    <!-- Task 3 (Rekayasa Perangkat Lunak) -->
                    <a href="/dosen/tugas/detail/mock-3" class="dosen-submission-task-card" data-course-id="3">
                        <div class="task-card-header">
                            <span class="badge-tag teal">Rekayasa Perangkat Lunak</span>
                            <span class="badge-tag outline">Kelompok</span>
                        </div>
                        <h3 class="task-card-title">Desain Arsitektur Sistem dengan UML Diagram</h3>
                        <div class="task-card-footer">
                            <span><i class="bi bi-people"></i> 0 Mengumpulkan</span>
                            <span class="btn-action-detail">Periksa <i class="bi bi-chevron-right"></i></span>
                        </div>
                    </a>

                </div>
            </div>
        </t>
    </template>

    <!-- 4. TEMPLATE DETAIL TUGAS & FEEDBACK PENGUMPULAN MAHASISWA -->
    <template id="tugas_dosen_detail" name="Dosen Detail Pengumpulan Tugas">
        <t t-call="custom_web.layout">
            <div class="dosen-tugas-container">
                <!-- HUD Header -->
                <div class="dosen-header-hud">
                    <div class="dosen-profile-info">
                        <div class="dosen-avatar-wrapper">
                            <t t-esc="dosen.name[0] if dosen and dosen.name else 'D'"/>
                        </div>
                        <div class="dosen-meta">
                            <h2 class="dosen-name" id="detail-hud-title">Detail Tugas &amp; Pengumpulan</h2>
                            <p class="dosen-role"><i class="bi bi-clipboard-data-fill"></i> Kelola nilai dan periksa dokumen tugas mahasiswa di sini</p>
                        </div>
                    </div>
                    <a href="/dosen/tugas/pengumpulan" class="btn-back-dashboard">
                        <i class="bi bi-arrow-left"></i> Kembali ke Daftar Tugas
                    </a>
                </div>

                <!-- Assignment Specs Card (Top) -->
                <div class="glass-panel mb-30" id="detail-specs-card">
                    <div class="detail-specs-header">
                        <div>
                            <span class="badge-tag purple" id="detail-spec-subject">Kecerdasan Buatan (AI)</span>
                            <span class="badge-tag outline" id="detail-spec-type">Individu</span>
                        </div>
                        <span class="val-deadline" id="detail-spec-deadline"><i class="bi bi-clock-fill"></i> Batas Waktu: 3 Juni 2026, 23:59 WIB</span>
                    </div>
                    <h2 class="detail-specs-title" id="detail-spec-title">Judul Tugas</h2>
                    <hr class="divider"/>
                    <div class="detail-specs-body">
                        <h5>Spesifikasi/Petunjuk Tugas:</h5>
                        <p id="detail-spec-desc">Deskripsi pengerjaan tugas...</p>
                    </div>
                </div>

                <!-- Student Submissions Table Card (Bottom) -->
                <div class="glass-panel">
                    <div class="card-header">
                        <span class="header-icon"><i class="bi bi-table"></i></span>
                        <h3>Daftar Pengumpulan Mahasiswa</h3>
                    </div>

                    <div class="table-responsive">
                        <table class="modern-table">
                            <thead>
                                <tr>
                                    <th>Mahasiswa</th>
                                    <th>Tanggal Pengumpulan</th>
                                    <th>Berkas / Tautan</th>
                                    <th>Catatan Mahasiswa</th>
                                    <th>Status Nilai</th>
                                    <th style="width: 180px;">Penilaian</th>
                                </tr>
                            </thead>
                            <tbody id="submissions-table-body">
                                <!-- Mock Student Submissions will be populated by tugas_dosen.js based on tugas_id -->
                                <tr>
                                    <td colspan="6" class="text-center py-40">
                                        <div class="spinner-border text-primary" role="status">
                                            <span class="visually-hidden">Memuat berkas pengumpulan...</span>
                                        </div>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            <div class="glowing-toast-container" id="toast-container"></div>
        </t>
    </template>

</odoo>
