<odoo>
    <!-- 1. TEMPLATE MENU UTAMA PRESENSI DOSEN -->
    <template id="presensi_dosen_menu" name="Menu Utama Presensi Dosen">
        <t t-call="custom_web.layout">
            <script src="/custom_web/static/src/js/dosen_presensi.js?v=14" type="text/javascript"></script>

            <div class="dosen-presensi-container">
                <!-- Top Header HUD -->
                <div class="dosen-header-hud">
                    <div class="dosen-profile-info">
                        <div class="dosen-avatar-wrapper">
                            <t t-if="dosen and dosen.foto_profil">
                                <img t-att-src="'data:image/png;base64,' + dosen.foto_profil.decode('utf-8')" alt="Profile"/>
                            </t>
                            <t t-else="">
                                <img src="/custom_web/static/src/img/avatar_default.png" alt="Profile"/>
                            </t>
                        </div>
                        <div class="dosen-meta">
                            <h2 class="dosen-name"><t t-esc="dosen.name if dosen else 'Dosen'"/></h2>
                            <p class="dosen-role"><i class="bi bi-shield-check"></i> <span data-translate-id="dosen_presensi_portal">Portal Presensi Dosen</span> (NIP: <t t-esc="dosen.nip if dosen else 'N/A'"/>)</p>
                        </div>
                    </div>
                    <a href="/dashboard" class="btn-back-dashboard">
                        <i class="bi bi-arrow-left"></i> <span data-translate-id="dosen_btn_back_dashboard">Kembali ke Dashboard</span>
                    </a>
                </div>

                <!-- Intermediate Navigation Cards -->
                <div class="dosen-menu-tugas-grid">

                    <!-- Card 1: Buka Sesi Presensi Baru -->
                    <a href="/dosen/presensi/buat" class="glass-menu-card purple-glow">
                        <div class="card-glow-bg"></div>
                        <div class="card-icon-circle">
                            <i class="bi bi-plus-circle-fill"></i>
                        </div>
                        <h3 data-translate-id="card_attendance_btn">Buka Sesi Presensi</h3>
                    </a>

                    <!-- Card 2: Riwayat Presensi Dosen -->
                    <a href="/dosen/presensi/histori" class="glass-menu-card blue-glow">
                        <div class="card-glow-bg"></div>
                        <div class="card-icon-circle">
                            <i class="bi bi-clock-history"></i>
                        </div>
                        <h3 data-translate-id="dosen_presensi_history">Riwayat Presensi</h3>
                    </a>

                </div>

                <!-- ===== SECTION SESI PRESENSI AKTIF ===== -->
                <t t-if="open_sessions">
                    <div class="menu-active-sessions-section">
                        <div class="section-header-row">
                            <span class="live-dot-pulse"></span>
                            <h3 class="section-title-live" data-translate-id="dosen_presensi_active_title">Sesi Presensi Aktif</h3>
                            <span class="live-count-badge"><t t-esc="len(open_sessions)"/> <span data-translate-id="dosen_presensi_running">sesi berjalan</span></span>
                        </div>

                        <div id="sesi-aktif-list" class="sessions-container">
                            <t t-foreach="open_sessions" t-as="sesi">
                                <div class="session-active-item session-card-clickable"
                                     t-att-id="'sesi-item-' + str(sesi.id)"
                                     t-attf-data-detail-url="/dosen/presensi/aktif/#{sesi.id}">
                                    <div class="session-item-header">
                                        <div class="session-title-block">
                                            <h4><t t-esc="sesi.name"/></h4>
                                            <p class="matkul"><t t-esc="sesi.mata_kuliah_id.nama"/></p>
                                        </div>
                                        <t t-if="sesi.tipe_kelas == 'online'">
                                            <span class="type-badge online"><i class="bi bi-laptop"></i> <span data-translate-id="pre_online">Online</span></span>
                                        </t>
                                        <t t-else="">
                                            <span class="type-badge offline"><i class="bi bi-geo-alt-fill"></i> <span data-translate-id="pre_offline">Offline</span></span>
                                        </t>
                                    </div>

                                    <div class="session-item-body">
                                        <div class="stats-row">
                                            <div class="stat-box">
                                                <span class="number"><t t-esc="sesi.total_hadir"/></span>
                                                <span class="label" data-translate-id="dosen_presensi_present">Mahasiswa Hadir</span>
                                            </div>
                                            <div class="stat-box info">
                                                <span class="label-info"><strong><span data-translate-id="dosen_presensi_open_time">Waktu Buka:</span></strong></span>
                                                <span class="value-info time-format"><span t-field="sesi.waktu_buka" t-options="{'widget': 'datetime', 'format': 'yyyy-MM-dd HH:mm:ss'}"/></span>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="session-item-footer">
                                        <button type="button" class="btn-tutup-sesi" t-att-data-id="sesi.id" style="width: 100%;">
                                            <i class="bi bi-stop-circle-fill"></i> <span data-translate-id="dosen_presensi_btn_close">Tutup Sesi Presensi</span>
                                        </button>
                                    </div>

                                </div>
                            </t>
                        </div>
                    </div>
                </t>


            </div>
        </t>
    </template>


    <!-- 2. TEMPLATE BUAT / BUKA SESI PRESENSI BARU -->
    <template id="presensi_dosen_buat" name="Buka Sesi Presensi Dosen">
        <t t-call="custom_web.layout">
            <script src="/custom_web/static/src/js/dosen_presensi.js?v=14" type="text/javascript"></script>

            <div class="dosen-presensi-container">
                <!-- Top Header HUD -->
                <div class="dosen-header-hud">
                    <div class="dosen-profile-info">
                        <div class="dosen-avatar-wrapper">
                            <t t-if="dosen and dosen.foto_profil">
                                <img t-att-src="'data:image/png;base64,' + dosen.foto_profil.decode('utf-8')" alt="Profile"/>
                            </t>
                            <t t-else="">
                                <img src="/custom_web/static/src/img/avatar_default.png" alt="Profile"/>
                            </t>
                        </div>
                        <div class="dosen-meta">
                            <h2 class="dosen-name">Buka Sesi Presensi</h2>
                            <p class="dosen-role"><i class="bi bi-broadcast"></i> Mulai dan kelola sesi presensi aktif mahasiswa Anda</p>
                        </div>
                    </div>
                    <a href="/dosen/presensi" class="btn-back-dashboard">
                        <i class="bi bi-arrow-left"></i> <span>Kembali ke Menu Presensi</span>
                    </a>
                </div>

                <div class="dosen-presensi-single">
                    <!-- Form Buka Sesi Baru -->
                    <div class="dosen-form-card glass-panel">
                        <div class="card-header">
                            <span class="header-icon"><i class="bi bi-plus-circle-fill"></i></span>
                            <h3>Buka Sesi Presensi Baru</h3>
                        </div>
                        <form id="formBukaSesi" class="modern-form">
                            <!-- Nama Sesi -->
                            <div class="form-group">
                                <label for="nama_sesi">Nama Sesi <span class="required">*</span></label>
                                <input type="text" id="nama_sesi" name="nama_sesi" placeholder="Contoh: Pertemuan 5" required="required" class="form-control"/>
                            </div>

                            <!-- Mata Kuliah (Custom Select with Search) -->
                            <div class="form-group mk-dropdown-group">
                                <label for="mata_kuliah_btn">Mata Kuliah <span class="required">*</span></label>
                                <div class="custom-select-container">
                                    <button type="button" id="mata_kuliah_btn" class="form-control select-trigger-btn">
                                        <span id="selected_course_text">-- Pilih Mata Kuliah --</span>
                                        <i class="bi bi-chevron-down dropdown-arrow-icon"></i>
                                    </button>
                                    <input type="hidden" id="mata_kuliah_id" name="mata_kuliah_id" required="required"/>
                                    <div id="mata_kuliah_dropdown" class="custom-select-pane hidden">
                                        <div class="search-box-wrapper">
                                            <i class="bi bi-search search-icon"></i>
                                            <input type="text" id="mata_kuliah_search" placeholder="Cari mata kuliah..." autocomplete="off" class="dropdown-search-input"/>
                                        </div>
                                        <div class="dropdown-options-list">
                                            <t t-foreach="courses_list" t-as="c">
                                                <div class="dropdown-option-item" t-att-data-id="c.id" t-att-data-name="c.nama" t-att-data-code="c.kode">
                                                    <span class="course-code"><t t-esc="c.kode"/></span> - <span class="course-name"><t t-esc="c.nama"/></span> <span class="course-sem">(Sem <t t-esc="c.semester"/>)</span>
                                                </div>
                                            </t>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Tipe Kelas (Segmented Toggle) -->
                            <div class="form-group">
                                <label>Tipe Kelas <span class="required">*</span></label>
                                <div class="segmented-control">
                                    <input type="radio" id="type_offline" name="tipe_kelas" value="offline" checked="checked"/>
                                    <label for="type_offline" class="segmented-label offline-label">
                                        <i class="bi bi-geo-alt-fill"></i> Luring (Offline)
                                    </label>

                                    <input type="radio" id="type_online" name="tipe_kelas" value="online"/>
                                    <label for="type_online" class="segmented-label online-label">
                                        <i class="bi bi-laptop"></i> Daring (Online)
                                    </label>
                                </div>
                            </div>

                            <!-- Koordinat GPS & Radius (Akan disembunyikan jika Online) -->
                            <div id="gps-fields-container" class="gps-fields-wrapper">
                                <div class="form-row">
                                    <div class="form-group half">
                                        <label for="latitude">Latitude <span class="required">*</span></label>
                                        <input type="number" step="any" id="latitude" name="latitude" placeholder="0.0" class="form-control"/>
                                    </div>
                                    <div class="form-group half">
                                        <label for="longitude">Longitude <span class="required">*</span></label>
                                        <input type="number" step="any" id="longitude" name="longitude" placeholder="0.0" class="form-control"/>
                                    </div>
                                </div>

                                <div class="gps-detection-box">
                                    <button type="button" id="btnDapatkanLokasi" class="btn-location-fetch">
                                        <i class="bi bi-cursor-fill pulsing-icon"></i> Dapatkan Lokasi GPS Saya
                                    </button>
                                    <div id="gps-status" class="gps-status-text">Lokasi belum terdeteksi.</div>
                                </div>

                                <div class="form-group">
                                    <label for="radius_meter">Radius Batas Hadir (meter) <span class="required">*</span></label>
                                    <input type="number" id="radius_meter" name="radius_meter" value="100" class="form-control"/>
                                    <span class="input-helper">Jarak toleransi maksimal mahasiswa dari kelas.</span>
                                </div>
                            </div>

                            <!-- Batas Waktu Telat -->
                            <div class="form-group">
                                <label for="batas_waktu_telat">Batas Waktu Tepat Waktu <span class="required">*</span></label>
                                <input type="datetime-local" id="batas_waktu_telat" name="batas_waktu_telat" required="required" class="form-control"/>
                                <span class="input-helper">Mahasiswa yang hadir lewat waktu ini akan dicatat "Terlambat" (Reward +0).</span>
                            </div>

                            <!-- Submit Button -->
                            <button type="submit" id="btnSubmitSesi" class="btn-submit-sesi">
                                <i class="bi bi-check2-circle"></i> Mulai Sesi Presensi
                            </button>
                        </form>
                    </div>

                </div>

                <!-- Modal Pop Up Sukses Buka Sesi -->
                <div id="successModal" class="custom-modal-overlay">
                    <div class="custom-modal-card">
                        <div class="modal-icon-wrapper">
                            <i class="bi bi-check-lg"></i>
                        </div>
                        <h3 class="modal-title">Berhasil Membuat Presensi</h3>
                        <p class="modal-message">Sesi presensi telah berhasil dibuat dan saat ini sedang aktif.</p>
                        <button type="button" id="btnModalClose" class="btn-modal-primary">
                            <span>Kembali ke Portal</span> <i class="bi bi-arrow-right"></i>
                        </button>
                    </div>
                </div>

            </div>
        </t>
    </template>

    <!-- 3. TEMPLATE RIWAYAT / HISTORI SESI PRESENSI -->
    <template id="presensi_dosen_histori" name="Riwayat Presensi Dosen">
        <t t-call="custom_web.layout">
            <script src="/custom_web/static/src/js/dosen_presensi.js?v=14" type="text/javascript"></script>

            <div class="dosen-presensi-container">
                <!-- Top Header HUD -->
                <div class="dosen-header-hud">
                    <div class="dosen-profile-info">
                        <div class="dosen-avatar-wrapper">
                            <t t-if="dosen and dosen.foto_profil">
                                <img t-att-src="'data:image/png;base64,' + dosen.foto_profil.decode('utf-8')" alt="Profile"/>
                            </t>
                            <t t-else="">
                                <img src="/custom_web/static/src/img/avatar_default.png" alt="Profile"/>
                            </t>
                        </div>
                        <div class="dosen-meta">
                            <h2 class="dosen-name" data-translate-id="dosen_presensi_history_title">Riwayat Sesi Presensi</h2>
                            <p class="dosen-role"><i class="bi bi-clock-history"></i> <span data-translate-id="dosen_presensi_history_subtitle">Daftar lengkap sesi presensi yang telah diselesaikan</span></p>
                        </div>
                    </div>
                    <a href="/dosen/presensi" class="btn-back-dashboard">
                        <i class="bi bi-arrow-left"></i> <span data-translate-id="dosen_presensi_btn_back_menu">Kembali ke Menu Presensi</span>
                    </a>
                </div>

                <!-- Riwayat Sesi Presensi Table Section -->
                <div class="riwayat-section glass-panel">
                    <div class="card-header">
                        <span class="header-icon"><i class="bi bi-clock-history"></i></span>
                        <h3 data-translate-id="dosen_presensi_history_card_title">Riwayat Sesi Presensi Dosen</h3>
                    </div>

                    <div class="table-responsive">
                        <table class="modern-table">
                            <thead>
                                <tr>
                                    <th data-translate-id="dosen_presensi_th_session">Nama Sesi</th>
                                    <th data-translate-id="dosen_presensi_th_course">Mata Kuliah</th>
                                    <th data-translate-id="dosen_presensi_th_type">Tipe</th>
                                    <th data-translate-id="dosen_presensi_th_open_time">Waktu Buka</th>
                                    <th data-translate-id="dosen_presensi_th_close_time">Waktu Tutup</th>
                                    <th data-translate-id="dosen_presensi_th_total_present">Total Hadir</th>
                                    <th data-translate-id="dosen_presensi_th_status">Status</th>
                                </tr>
                            </thead>
                            <tbody id="riwayat-table-body">
                                <t t-if="not closed_sessions">
                                    <tr class="row-empty">
                                        <td colspan="7" data-translate-id="dosen_presensi_no_history">Belum ada riwayat sesi presensi yang ditutup.</td>
                                    </tr>
                                </t>
                                <t t-else="">
                                    <t t-foreach="closed_sessions" t-as="sesi">
                                        <tr t-att-data-id="sesi.id">
                                            <td class="bold"><t t-esc="sesi.name"/></td>
                                            <td><t t-esc="sesi.mata_kuliah_id.nama"/></td>
                                            <td>
                                                <t t-if="sesi.tipe_kelas == 'online'">
                                                    <span class="badge online" data-translate-id="pre_online">Online</span>
                                                </t>
                                                <t t-else="">
                                                    <span class="badge offline" data-translate-id="pre_offline">Offline</span>
                                                </t>
                                            </td>
                                            <td class="time-format"><span t-field="sesi.waktu_buka" t-options="{'widget': 'datetime', 'format': 'yyyy-MM-dd HH:mm:ss'}"/></td>
                                            <td class="time-format"><span t-field="sesi.waktu_tutup" t-options="{'widget': 'datetime', 'format': 'yyyy-MM-dd HH:mm:ss'}"/></td>
                                            <td class="center bold text-primary"><t t-esc="sesi.total_hadir"/> Mhs</td>
                                            <td><span class="status-badge closed"><span data-translate-id="tugas_completed">Selesai</span></span></td>
                                        </tr>
                                    </t>
                                </t>
                            </tbody>
                        </table>
                    </div>
                </div>

            </div>
        </t>
    </template>

    <!-- 4. TEMPLATE DETAIL SESI PRESENSI -->
    <template id="presensi_dosen_histori_detail" name="Detail Sesi Presensi Dosen">
        <t t-call="custom_web.layout">
            <script src="/custom_web/static/src/js/dosen_presensi.js?v=14" type="text/javascript"></script>

            <div class="dosen-presensi-container">
                <!-- Top Header HUD -->
                <div class="dosen-header-hud">
                    <div class="dosen-profile-info">
                        <div class="dosen-avatar-wrapper">
                            <t t-if="dosen and dosen.foto_profil">
                                <img t-att-src="'data:image/png;base64,' + dosen.foto_profil.decode('utf-8')" alt="Profile"/>
                            </t>
                            <t t-else="">
                                <img src="/custom_web/static/src/img/avatar_default.png" alt="Profile"/>
                            </t>
                        </div>
                        <div class="dosen-meta">
                            <h2 class="dosen-name">Detail Sesi: <t t-esc="sesi.name"/></h2>
                            <p class="dosen-role"><i class="bi bi-info-circle"></i> <t t-esc="sesi.mata_kuliah_id.nama"/> (<t t-esc="'Online' if sesi.tipe_kelas == 'online' else 'Offline'"/>)</p>
                        </div>
                    </div>
                    <a href="/dosen/presensi/histori" class="btn-back-dashboard">
                        <i class="bi bi-arrow-left"></i> <span>Kembali ke Riwayat</span>
                    </a>
                </div>

                <!-- Session Metadata Summary Cards -->
                <div class="detail-summary-grid">
                    <div class="summary-card glass-panel">
                        <div class="card-icon blue"><i class="bi bi-calendar-event"></i></div>
                        <div class="card-info">
                            <span class="value time-format"><span t-field="sesi.waktu_buka" t-options="{'widget': 'datetime', 'format': 'yyyy-MM-dd HH:mm:ss'}"/></span>
                            <span class="label">Waktu Buka</span>
                        </div>
                    </div>
                    <div class="summary-card glass-panel">
                        <div class="card-icon red"><i class="bi bi-calendar-check-fill"></i></div>
                        <div class="card-info">
                            <span class="value time-format"><span t-field="sesi.waktu_tutup" t-options="{'widget': 'datetime', 'format': 'yyyy-MM-dd HH:mm:ss'}"/></span>
                            <span class="label">Waktu Tutup</span>
                        </div>
                    </div>
                    <div class="summary-card glass-panel">
                        <div class="card-icon green"><i class="bi bi-people-fill"></i></div>
                        <div class="card-info">
                            <span class="value"><t t-esc="sesi.total_hadir"/> Mhs</span>
                            <span class="label">Total Kehadiran</span>
                        </div>
                    </div>
                </div>

                <!-- Panel Konten Utama -->
                <div class="aktif-detail-panel glass-panel">
                    <!-- Tab Headers -->
                    <div class="aktif-tab-header">
                        <button id="tab-btn-hadir" class="aktif-tab-btn active" data-tab="tab-panel-hadir">
                            <i class="bi bi-person-check"></i>
                            Sudah Hadir (<t t-esc="len(hadir_ids)"/>)
                        </button>
                        <button id="tab-btn-belum" class="aktif-tab-btn" data-tab="tab-panel-belum">
                            <i class="bi bi-person-dash"></i>
                            Belum Hadir (<t t-esc="total_mhs - len(hadir_ids)"/>)
                        </button>
                    </div>

                    <!-- Tab Panel: Sudah Hadir -->
                    <div id="tab-panel-hadir" class="aktif-tab-content active">
                        <div class="table-responsive">
                            <table class="modern-table">
                                <thead>
                                    <tr>
                                        <th>NIM</th>
                                        <th>Nama Mahasiswa</th>
                                        <th>Waktu Presensi</th>
                                        <th>Status Kehadiran</th>
                                        <th>Metode</th>
                                        <th>Koin Didapat</th>
                                        <th>XP Didapat</th>
                                    </tr>
                                </thead>
                                <tbody id="detail-table-body">
                                    <t t-if="not records">
                                        <tr class="row-empty">
                                            <td colspan="7">Tidak ada mahasiswa yang hadir pada sesi ini.</td>
                                        </tr>
                                    </t>
                                    <t t-else="">
                                        <t t-foreach="records" t-as="r">
                                            <tr>
                                                <td class="bold"><t t-esc="r.mahasiswa_id.nim"/></td>
                                                <td><t t-esc="r.mahasiswa_id.name"/></td>
                                                <td class="time-format"><span t-field="r.waktu_presensi" t-options="{'widget': 'datetime', 'format': 'yyyy-MM-dd HH:mm:ss'}"/></td>
                                                <td>
                                                    <t t-if="r.status_kehadiran == 'tepat_waktu'">
                                                        <span class="badge online">Tepat Waktu</span>
                                                    </t>
                                                    <t t-else="">
                                                        <span class="badge offline">Terlambat</span>
                                                    </t>
                                                </td>
                                                <td>
                                                    <t t-if="r.is_manual">
                                                        <span class="badge-text manual"><i class="bi bi-pencil-square"></i> Manual</span>
                                                    </t>
                                                    <t t-else="">
                                                        <span class="badge-text auto"><i class="bi bi-phone"></i> Mandiri (App/Web)</span>
                                                    </t>
                                                </td>
                                                <td class="bold text-accent">+<t t-esc="r.koin_didapat"/> Koin</td>
                                                <td class="bold text-primary">+<t t-esc="r.xp_didapat"/> XP</td>
                                            </tr>
                                        </t>
                                    </t>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-- Tab Panel: Belum Hadir (dengan presensi manual) -->
                    <div id="tab-panel-belum" class="aktif-tab-content">
                        <div class="belum-hadir-container">
                            <t t-set="belum_hadir_count" t-value="0"/>
                            <t t-if="sesi.mata_kuliah_id">
                                <t t-foreach="sesi.mata_kuliah_id.mahasiswa_ids.sorted(key=lambda m: m.nim or '')" t-as="mhs">
                                    <t t-if="mhs.id not in hadir_ids">
                                        <t t-set="belum_hadir_count" t-value="belum_hadir_count + 1"/>
                                        <div class="belum-hadir-item" t-att-id="'mhs-item-' + str(sesi.id) + '-' + str(mhs.id)">
                                            <div class="student-info">
                                                <span class="name"><t t-esc="mhs.name"/></span>
                                                <span class="nim"><t t-esc="mhs.nim"/></span>
                                            </div>
                                            <button type="button" class="btn-presensi-manual" t-att-data-sesi-id="sesi.id" t-att-data-mhs-id="mhs.id">
                                                <i class="bi bi-check-lg"></i>
                                            </button>
                                        </div>
                                    </t>
                                </t>
                            </t>
                            <t t-if="belum_hadir_count == 0">
                                <div class="empty-state" style="padding: 40px 20px;">
                                    <i class="bi bi-check-circle-fill" style="font-size: 2.5rem; color: #10b981;"></i>
                                    <p>Semua mahasiswa sudah melakukan presensi!</p>
                                </div>
                            </t>
                        </div>

                        <!-- Sticky Batch Submit Button -->
                        <div id="batch-submit-bar" class="batch-submit-container hidden">
                            <button type="button" id="btn-submit-batch-presensi" class="btn-submit-batch" t-att-data-sesi-id="sesi.id">
                                <i class="bi bi-person-check-fill"></i> Simpan Kehadiran (<span id="batch-count">0</span> terpilih)
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <!-- 5. TEMPLATE HALAMAN DETAIL SESI AKTIF -->
    <template id="presensi_dosen_aktif_detail" name="Detail Sesi Aktif Dosen">
        <t t-call="custom_web.layout">
            <script src="/custom_web/static/src/js/dosen_presensi.js?v=14" type="text/javascript"></script>

            <div class="dosen-presensi-container">
                <!-- Top Header HUD -->
                <div class="dosen-header-hud">
                    <div class="dosen-profile-info">
                        <div class="dosen-avatar-wrapper">
                            <t t-if="dosen and dosen.foto_profil">
                                <img t-att-src="'data:image/png;base64,' + dosen.foto_profil.decode('utf-8')" alt="Profile"/>
                            </t>
                            <t t-else="">
                                <img src="/custom_web/static/src/img/avatar_default.png" alt="Profile"/>
                            </t>
                        </div>
                        <div class="dosen-meta">
                            <h2 class="dosen-name"><t t-esc="sesi.name"/></h2>
                            <p class="dosen-role">
                                <i class="bi bi-broadcast"></i>
                                <t t-esc="sesi.mata_kuliah_id.nama"/>
                                &#8212;
                                <span class="live-badge-inline">&#x25cf; Sesi Aktif</span>
                            </p>
                        </div>
                    </div>
                    <a href="/dosen/presensi" class="btn-back-dashboard">
                        <i class="bi bi-arrow-left"></i> <span data-translate-id="dosen_btn_back_menu">Kembali ke Menu</span>
                    </a>
                </div>

                <!-- Stat Cards Ringkasan -->
                <div class="aktif-detail-stats">
                    <div class="aktif-stat-card green">
                        <span class="stat-icon"><i class="bi bi-person-check-fill"></i></span>
                        <div class="stat-info">
                            <span class="stat-num"><t t-esc="len(hadir_ids)"/></span>
                            <span class="stat-lbl" data-translate-id="dosen_pres_stat_present">Sudah Hadir</span>
                        </div>
                    </div>
                    <div class="aktif-stat-card amber">
                        <span class="stat-icon"><i class="bi bi-person-x-fill"></i></span>
                        <div class="stat-info">
                            <span class="stat-num"><t t-esc="total_mhs - len(hadir_ids)"/></span>
                            <span class="stat-lbl" data-translate-id="dosen_pres_stat_absent">Belum Hadir</span>
                        </div>
                    </div>
                    <div class="aktif-stat-card blue">
                        <span class="stat-icon"><i class="bi bi-people-fill"></i></span>
                        <div class="stat-info">
                            <span class="stat-num"><t t-esc="total_mhs"/></span>
                            <span class="stat-lbl" data-translate-id="dosen_pres_stat_total_students">Total Mahasiswa</span>
                        </div>
                    </div>
                    <div class="aktif-stat-card purple">
                        <span class="stat-icon"><i class="bi bi-clock-fill"></i></span>
                        <div class="stat-info">
                            <span class="stat-num time-format"><span t-field="sesi.waktu_buka" t-options="{'widget': 'datetime', 'format': 'HH:mm'}"/></span>
                            <span class="stat-lbl" data-translate-id="dosen_presensi_open_time">Waktu Buka</span>
                        </div>
                    </div>
                </div>

                <!-- Panel Konten Utama -->
                <div class="aktif-detail-panel glass-panel">
                    <!-- Tab Headers -->
                    <div class="aktif-tab-header">
                        <button id="tab-btn-hadir" class="aktif-tab-btn active" data-tab="tab-panel-hadir">
                            <i class="bi bi-person-check"></i>
                            <span data-translate-id="dosen_pres_stat_present">Sudah Hadir</span> (<t t-esc="len(hadir_ids)"/>)
                        </button>
                        <button id="tab-btn-belum" class="aktif-tab-btn" data-tab="tab-panel-belum">
                            <i class="bi bi-person-dash"></i>
                            <span data-translate-id="dosen_pres_stat_absent">Belum Hadir</span> (<t t-esc="total_mhs - len(hadir_ids)"/>)
                        </button>
                    </div>

                    <!-- Tab Panel: Sudah Hadir -->
                    <div id="tab-panel-hadir" class="aktif-tab-content active">
                        <div class="table-responsive">
                            <table class="modern-table">
                                <thead>
                                    <tr>
                                        <th data-translate-id="pre_info_name">Nama Mahasiswa</th>
                                        <th data-translate-id="pre_info_nim">NIM</th>
                                        <th data-translate-id="dosen_pres_th_time">Waktu Presensi</th>
                                        <th data-translate-id="dosen_pres_th_status">Status</th>
                                        <th data-translate-id="dosen_pres_th_method">Metode</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-if="not hadir_records">
                                        <tr class="row-empty">
                                            <td colspan="5" data-translate-id="dosen_pres_no_students_present">Belum ada mahasiswa yang hadir pada sesi ini.</td>
                                        </tr>
                                    </t>
                                    <t t-else="">
                                        <t t-foreach="hadir_records" t-as="r">
                                            <tr>
                                                <td><strong><t t-esc="r.mahasiswa_id.name"/></strong></td>
                                                <td class="bold text-muted"><t t-esc="r.mahasiswa_id.nim"/></td>
                                                <td class="time-format"><span t-field="r.waktu_presensi" t-options="{'widget': 'datetime', 'format': 'HH:mm:ss'}"/></td>
                                                <td>
                                                    <t t-if="r.status_kehadiran == 'tepat_waktu'">
                                                        <span class="badge online" data-translate-id="dosen_pres_status_present">Tepat Waktu</span>
                                                    </t>
                                                    <t t-else="">
                                                        <span class="badge offline" data-translate-id="dosen_pres_status_late">Terlambat</span>
                                                    </t>
                                                </td>
                                                <td>
                                                    <t t-if="r.is_manual">
                                                        <span class="badge-text manual"><i class="bi bi-pencil-square"></i> <span data-translate-id="dosen_pres_method_manual">Manual</span></span>
                                                    </t>
                                                    <t t-else="">
                                                        <span class="badge-text auto"><i class="bi bi-phone"></i> <span data-translate-id="dosen_pres_method_auto">Mandiri</span></span>
                                                    </t>
                                                </td>
                                            </tr>
                                        </t>
                                    </t>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-- Tab Panel: Belum Hadir (dengan presensi manual) -->
                    <div id="tab-panel-belum" class="aktif-tab-content">
                        <div class="belum-hadir-container">
                            <t t-set="belum_hadir_count" t-value="0"/>
                            <t t-if="sesi.mata_kuliah_id">
                                <t t-foreach="sesi.mata_kuliah_id.mahasiswa_ids.sorted(key=lambda m: m.nim or '')" t-as="mhs">
                                    <t t-if="mhs.id not in hadir_ids">
                                        <t t-set="belum_hadir_count" t-value="belum_hadir_count + 1"/>
                                        <div class="belum-hadir-item" t-att-id="'mhs-item-' + str(sesi.id) + '-' + str(mhs.id)">
                                            <div class="student-info">
                                                <span class="name"><t t-esc="mhs.name"/></span>
                                                <span class="nim"><t t-esc="mhs.nim"/></span>
                                            </div>
                                            <button type="button" class="btn-presensi-manual" t-att-data-sesi-id="sesi.id" t-att-data-mhs-id="mhs.id">
                                                <i class="bi bi-check-lg"></i>
                                            </button>
                                        </div>
                                    </t>
                                </t>
                            </t>
                            <t t-if="belum_hadir_count == 0">
                                <div class="empty-state" style="padding: 40px 20px;">
                                    <i class="bi bi-check-circle-fill" style="font-size: 2.5rem; color: #10b981;"></i>
                                    <p data-translate-id="dosen_pres_all_students_present">Semua mahasiswa sudah melakukan presensi!</p>
                                </div>
                            </t>
                        </div>

                        <!-- Sticky Batch Submit Button -->
                        <div id="batch-submit-bar" class="batch-submit-container hidden">
                            <button type="button" id="btn-submit-batch-presensi" class="btn-submit-batch" t-att-data-sesi-id="sesi.id">
                                <i class="bi bi-person-check-fill"></i> <span data-translate-id="dosen_pres_btn_save_attendance">Simpan Kehadiran</span> (<span id="batch-count">0</span> <span data-translate-id="dosen_pres_selected">terpilih</span>)
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Tombol Aksi Bawah -->
                <div class="aktif-detail-actions">
                    <button type="button" class="btn-tutup-sesi" t-att-data-id="sesi.id" style="max-width: 300px; margin: 0 auto;">
                        <i class="bi bi-stop-circle-fill"></i> <span data-translate-id="dosen_presensi_btn_close">Tutup Sesi Presensi</span>
                    </button>
                </div>

            </div>
        </t>
    </template>

</odoo>
