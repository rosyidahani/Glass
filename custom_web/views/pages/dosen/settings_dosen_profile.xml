<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="settings_dosen_profile" name="Dosen Settings - Foto Profil">
        <t t-call="custom_web.layout">
            <link rel="stylesheet" href="/custom_web/static/src/css/settings.css"/>

            <div class="profile-container">
                <div class="profile-header">
                    <div class="profile-picture-wrapper">
                        <t t-if="dosen.foto_profil">
                            <img t-att-src="'data:image/png;base64,' + dosen.foto_profil.decode('utf-8')" class="profile-picture" style="object-fit: cover; width: 80px; height: 80px; border-radius: 50%; border: 2px solid var(--accent-color);"/>
                        </t>
                        <t t-else="">
                            <div class="profile-picture" style="background: linear-gradient(135deg, #3b82f6, #8b5cf6); width: 80px; height: 80px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 28px; font-weight: 800; color: #fff;">
                                <t t-esc="dosen.name[0].upper()"/>
                            </div>
                        </t>
                    </div>
                    <div class="profile-details">
                        <h2>Foto Profil</h2>
                        <p>NIP: <t t-esc="dosen.nip"/></p>
                    </div>
                </div>

                <div class="settings-list" style="margin-top: 12px;">
                    <form id="form_upload_foto_dosen" class="settings-item" style="margin:0;padding:0;" enctype="multipart/form-data">
                        <div class="settings-item" style="border:none;cursor:default;">
                            <div class="item-left">
                                <div class="item-icon"><i class="bi bi-image"></i></div>
                                <span>Upload foto profil</span>
                            </div>
                            <div style="margin-top:10px;display:flex;flex-direction:column;gap:10px;align-items:flex-start;">
                                <input id="foto_profil_input" name="foto_profil" type="file" accept="image/*"/>
                                <button type="submit" class="btn btn-primary">Simpan</button>
                            </div>
                        </div>
                    </form>

                    <a href="/dashboard/dosen/settings" class="settings-item">
                        <div class="item-left">
                            <div class="item-icon"><i class="bi bi-arrow-left"></i></div>
                            <span data-translate-id="dosen_btn_back">Kembali</span>
                        </div>
                    </a>
                </div>
            </div>
        </t>
    </template>
</odoo>

