<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="settings_dosen_theme" name="Dosen Settings - Tema">
        <t t-call="custom_web.layout">
            <link rel="stylesheet" href="/custom_web/static/src/css/settings.css"/>

            <div class="profile-container">
                <div class="profile-header">
                    <div class="profile-picture-wrapper">
                        <div class="profile-picture" style="background: linear-gradient(135deg, #3b82f6, #8b5cf6);">
                            <t t-esc="dosen.name[0].upper()"/>
                        </div>
                    </div>
                    <div class="profile-details">
                        <h2>Tema</h2>
                        <p>NIP: <t t-esc="dosen.nip"/></p>
                    </div>
                </div>

                <div class="settings-list" style="margin-top: 12px;">
                    <form id="form_set_tema" class="settings-item" style="padding:0;">
                        <div class="settings-item" style="border:none;cursor:default;">
                            <div class="item-left">
                                <div class="item-icon"><i class="bi bi-palette-fill"></i></div>
                                <span>Pilih tema</span>
                            </div>
                            <div style="display:flex;flex-direction:column;gap:10px;align-items:flex-start;margin-top:10px;">
                                <label><input type="radio" name="tema_preference" value="oceanbreeze"/> Oceanbreeze</label>
                                <label><input type="radio" name="tema_preference" value="midnight_slate"/> Midnight Slate</label>
                                <label><input type="radio" name="tema_preference" value="amethyst_dream"/> Amethyst Dream</label>
                            </div>
                            <div style="margin-top:10px;">
                                <button type="submit" class="btn btn-primary">Simpan</button>
                            </div>
                        </div>
                    </form>

                
                    </div>
                    <a href="/dashboard/dosen/settings" class="settings-item">

                        <div class="item-left">
                            <div class="item-icon"><i class="bi bi-arrow-left"></i></div>
                            <span>Kembali</span>
                        </div>
                    </a>
                </div>
            </div>
        </t>
    </template>
</odoo>

