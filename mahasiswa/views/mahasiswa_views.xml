<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_mahasiswa_tree" model="ir.ui.view">
        <field name="name">mahasiswa.mahasiswa.tree</field>
        <field name="model">mahasiswa.mahasiswa</field>
        <field name="arch" type="xml">
            <tree string="Data Mahasiswa">
                <field name="name" string="Nama"/>
                <field name="nim" string="NIM"/>
                <field name="semester" string="Semester"/>
                <field name="prodi" string="Program Studi"/>
                <field name="total_xp" string="Total XP"/>
                <field name="koin" string="Koin"/>
            </tree>
        </field>
    </record>

    <record id="view_mahasiswa_form" model="ir.ui.view">
        <field name="name">mahasiswa.mahasiswa.form</field>
        <field name="model">mahasiswa.mahasiswa</field>
        <field name="arch" type="xml">
            <form string="Data Mahasiswa">
                <sheet>
                    <div class="oe_button_box" name="button_box"/>
                    <field name="foto_profil" widget="image" class="oe_avatar"
                           options='{"size": [354, 472]}'/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Nama Mahasiswa"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Informasi Akademik">
                            <field name="nim"/>
                            <field name="password" password="True"/>
                            <field name="semester"/>
                            <field name="prodi"/>
                        </group>
                        <group string="Statistik">
                            <field name="total_xp"/>
                            <field name="koin"/>
                        </group>
                        <group string="Biometrik &amp; Perangkat">
                            <field name="device_id" readonly="1"/>
                            <field name="face_descriptor" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_mahasiswa_search" model="ir.ui.view">
        <field name="name">mahasiswa.mahasiswa.search</field>
        <field name="model">mahasiswa.mahasiswa</field>
        <field name="arch" type="xml">
            <search string="Cari Mahasiswa">
                <field name="nim"/>
                <field name="name"/>
                <filter string="Active" name="filter_active"
                        domain="[('active', '=', True)]"/>
                <filter string="Archived" name="filter_archived"
                        domain="[('active', '=', False)]"/>
                <group expand="0" string="Group By">
                    <filter string="Semester" name="group_semester"
                            context="{'group_by': 'semester'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_mahasiswa" model="ir.actions.act_window">
        <field name="name">Data Mahasiswa</field>
        <field name="res_model">mahasiswa.mahasiswa</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_mahasiswa_search"/>
        <field name="context">{'search_default_filter_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Belum ada data mahasiswa. Klik tombol "New" untuk menambahkan.
            </p>
        </field>
    </record>

    <menuitem id="menu_mahasiswa_root"
              name="Mahasiswa"
              sequence="20"/>

    <menuitem id="menu_mahasiswa_data"
              name="Data Mahasiswa"
              parent="menu_mahasiswa_root"
              action="action_mahasiswa"
              sequence="10"/>

</odoo>